<Window x:Class="YangTools.Revit.UI.DimTextOverrideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="标注文本替换"
        Height="340"
        Width="480"
        WindowStartupLocation="CenterScreen"
        Background="#FAF6F0"
        Foreground="#3A3028"
        FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI"
        AllowsTransparency="True"
        WindowStyle="None"
        BorderThickness="1"
        BorderBrush="#D5C8B8"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- 普通按钮样式 -->
        <Style x:Key="FlatButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#E8DFD0"/>
            <Setter Property="Foreground" Value="#3A3028"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#C8B8A0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border"
                                CornerRadius="5"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#DDD0C0"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#B0A088"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D0C4B0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 强调按钮样式（主操作按钮） -->
        <Style x:Key="AccentButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#A0734A"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border"
                                CornerRadius="5"
                                Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#8A5E38"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#7A5030"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 关闭按钮样式 -->
        <Style x:Key="CloseButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border"
                                CornerRadius="3"
                                Background="{TemplateBinding Background}"
                                Padding="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C05040"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="54"/>
        </Grid.RowDefinitions>

        <!-- 1. 顶部渐变标题栏 -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#8B6D4C" Offset="0.0"/>
                    <GradientStop Color="#C4A67A" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="标注文本替换" FontWeight="Bold" FontSize="17" Foreground="#FFFFFF"/>
                    <TextBlock Text="自定义标注显示内容" FontSize="11" Foreground="#E8D8C4" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- 关闭按钮 -->
                <Button Grid.Column="1"
                        Width="30"
                        Height="30"
                        Content="×"
                        FontSize="18"
                        FontWeight="Bold"
                        Style="{StaticResource CloseButtonStyle}"
                        Click="CloseButton_Click"/>
            </Grid>
        </Border>

        <!-- 2. 中间内容区域 -->
        <Grid Grid.Row="1" Margin="24,18,24,10">
            <StackPanel>
                <!-- 已选标注数量提示 -->
                <Border Background="#E8F0D8" BorderBrush="#A0C070" BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,0,0,16">
                    <TextBlock x:Name="TxtSelectedCount" Text="已选中 0 个标注" FontSize="13" Foreground="#5A7A3A" FontWeight="Medium"/>
                </Border>

                <!-- 替换文本输入区域 -->
                <TextBlock Text="替换文本：" FontSize="13" Foreground="#3A3028" FontWeight="Medium" Margin="0,0,0,6"/>
                <TextBox x:Name="TxtOverride"
                         Height="36"
                         FontSize="14"
                         Padding="10,6"
                         Background="#F5F0E8"
                         Foreground="#3A3028"
                         BorderBrush="#C8B8A0"
                         BorderThickness="1"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,12"/>

                <!-- 清除覆盖文本复选框 -->
                <CheckBox x:Name="ChkClear"
                          Content="清除覆盖文本（恢复为原始数值显示）"
                          FontSize="13"
                          Foreground="#3A3028"
                          Margin="0,0,0,14"
                          Checked="ChkClear_Checked"
                          Unchecked="ChkClear_Unchecked"/>

                <!-- 提示文字 -->
                <TextBlock Text="提示：输入数字字符串或任意文字，将替换标注中显示的数值。"
                           FontSize="11.5"
                           Foreground="#8A7A68"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <!-- 3. 底部操作栏 -->
        <Border Grid.Row="2" Background="#EDE6DA" BorderThickness="0,1,0,0" BorderBrush="#C8B8A0">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="取  消"
                            Style="{StaticResource FlatButton}"
                            Click="CloseButton_Click"
                            Margin="0,0,10,0"/>
                    <Button x:Name="BtnConfirm"
                            Content="确认替换"
                            Style="{StaticResource AccentButton}"
                            Click="BtnConfirm_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
