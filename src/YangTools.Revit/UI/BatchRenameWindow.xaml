<Window x:Class="YangTools.Revit.UI.BatchRenameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="批量重命名 (Batch Rename)" Width="400" SizeToContent="Height" MinHeight="260"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource WindowBg}" FontFamily="Microsoft YaHei"
        WindowStyle="ToolWindow">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="重命名规则：" FontWeight="Bold" Margin="0,0,0,10" Foreground="{DynamicResource PrimaryText}"/>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="添加前缀：" VerticalAlignment="Center"/>
            <TextBox x:Name="PrefixTextBox" Grid.Column="1" Padding="4"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="添加后缀：" VerticalAlignment="Center"/>
            <TextBox x:Name="SuffixTextBox" Grid.Column="1" Padding="4"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="查找：" VerticalAlignment="Center"/>
            <TextBox x:Name="FindTextBox" Grid.Column="1" Padding="4"/>
            <TextBlock Text="替换为：" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,5,0"/>
            <TextBox x:Name="ReplaceTextBox" Grid.Column="3" Padding="4"/>
        </Grid>

        <CheckBox x:Name="ApplyToFamilyCheckBox" Grid.Row="4" Content="同时重命名族名称 (Apply to Family Names)" Margin="0,5,0,5" Foreground="#5A4A38" VerticalAlignment="Center"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确认 (OK)" Width="80" Padding="5" Margin="0,0,10,0" Background="{DynamicResource AccentColor}" Foreground="White" BorderThickness="0" Click="OkButton_Click"/>
            <Button Content="取消 (Cancel)" Width="80" Padding="5" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
