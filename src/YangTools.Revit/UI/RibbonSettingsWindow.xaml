<Window x:Class="YangTools.Revit.UI.RibbonSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YangTools 设置" Height="550" Width="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="SharedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{DynamicResource WindowBg}" BorderBrush="{DynamicResource WindowBorder}" 
            BorderThickness="1" CornerRadius="8" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Height="40">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="{DynamicResource Color_TitleBarStart}" Offset="0"/>
                        <GradientStop Color="{DynamicResource Color_TitleBarEnd}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <TextBlock Text="YangTools 设置" Foreground="{DynamicResource TitleText}" FontWeight="Bold" 
                               VerticalAlignment="Center" Margin="15,0"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Width="40" Height="40" 
                            Click="CloseButton_Click" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border x:Name="bg" Background="Transparent">
                                    <Path Data="M 12 12 L 28 28 M 28 12 L 12 28" 
                                          Stroke="{DynamicResource TitleText}" StrokeThickness="2"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource TitleCloseHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Row="1" Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Theme Selector -->
                <GroupBox Grid.Row="0" Header="主题配色" Foreground="{DynamicResource PrimaryText}" 
                          BorderBrush="{DynamicResource WindowBorder}" Margin="0,0,0,10" Padding="10">
                    <ItemsControl x:Name="ThemeList" Margin="0,5">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="120" Height="70" Margin="5" Cursor="Hand"
                                        Background="{DynamicResource PanelBg}" 
                                        BorderBrush="{DynamicResource WindowBorder}" BorderThickness="1"
                                        CornerRadius="4" MouseLeftButtonDown="Theme_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Border Width="40" Height="20" CornerRadius="3" Margin="0,0,0,6"
                                                Background="{Binding PreviewColor}"/>
                                        <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource PrimaryText}"
                                                   FontSize="12" TextAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </GroupBox>

                <!-- Ribbon Panel Settings -->
                <GroupBox Grid.Row="1" Header="Ribbon 面板可见性" Foreground="{DynamicResource PrimaryText}"
                          BorderBrush="{DynamicResource WindowBorder}" Padding="10">
                    <DockPanel>
                        <TextBlock Text="勾选的功能将在主面板直接显示，未勾选的将折叠到下拉菜单中。"
                                   TextWrapping="Wrap" Foreground="{DynamicResource SecondaryText}" FontSize="12"
                                   DockPanel.Dock="Top" Margin="0,0,0,8"/>
                        <TabControl x:Name="PanelTabControl" 
                                    Background="{DynamicResource InputBg}" 
                                    BorderBrush="{DynamicResource WindowBorder}" BorderThickness="1"/>
                    </DockPanel>
                </GroupBox>
            </Grid>

            <!-- Bottom Bar -->
            <Border Grid.Row="2" Background="{DynamicResource BottomBarBg}" 
                    BorderBrush="{DynamicResource WindowBorder}" BorderThickness="0,1,0,0" Padding="15,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Style="{StaticResource StandardButton}" 
                            Click="Cancel_Click" Width="80" Margin="0,0,10,0"/>
                    <Button Content="保存并应用" Style="{StaticResource PrimaryButton}" 
                            Click="Save_Click" Width="120"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
