<Window x:Class="YangTools.Revit.UI.RibbonSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YangTools 界面自定义设置" Height="500" Width="400"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="勾选的功能将在主面板直接显示，未勾选的将折叠到下拉菜单中。" TextWrapping="Wrap" Margin="0,0,0,10" Foreground="#555"/>

        <TabControl x:Name="PanelTabControl" Grid.Row="1" Background="White" BorderBrush="#CCC" BorderThickness="1">
            <!-- Tabs will be populated dynamically -->
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="取消 (Cancel)" Width="80" Height="30" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="保存并应用 (Save)" Width="120" Height="30" Background="#007ACC" Foreground="White" BorderThickness="0" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
