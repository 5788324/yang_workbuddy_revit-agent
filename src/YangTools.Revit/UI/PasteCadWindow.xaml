<Window x:Class="YangTools.Revit.UI.PasteCadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="从 CAD 粘贴"
        Height="540" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource PrimaryText}"
        FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI"
        AllowsTransparency="True"
        WindowStyle="None"
        BorderThickness="1"
        BorderBrush="{DynamicResource WindowBorder}"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- 普通按钮 -->
        <Style x:Key="FlatButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource BtnBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BtnBorder}"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bd" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource BtnHover}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D0C0A8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#B0A898"/>
                                <Setter TargetName="bd" Property="Background" Value="#EDE8E0"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#D8D0C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 强调色按钮 -->
        <Style x:Key="AccentButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bd" CornerRadius="6"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#704A28"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource BtnBorder}"/>
                                <Setter TargetName="bd" Property="Background" Value="#C8B090"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem 样式 -->
        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="itemBd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="itemBd" Property="Background" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBd" Property="Background" Value="#7A5535"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="58"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="{DynamicResource Color_TitleBarStart}" Offset="0"/>
                    <GradientStop Color="{DynamicResource Color_TitleBarEnd}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Text="从 CAD 粘贴" FontWeight="Bold" FontSize="17" Foreground="#FFFFFF"/>
                    <TextBlock Text=" |  AutoCAD → Revit 几何导入" FontSize="12"
                               Foreground="#E8D8C4" Margin="8,3,0,0" VerticalAlignment="Bottom"/>
                </StackPanel>
                <Button Grid.Column="1" Width="32" Height="32"
                        Content="✕" FontSize="15" FontWeight="Bold"
                        Foreground="#FFFFFF" Cursor="Hand"
                        Click="CancelButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="closebd" Background="Transparent" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="closebd" Property="Background" Value="{DynamicResource DangerBg}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- 内容区 -->
        <StackPanel Grid.Row="1" Margin="22,16,22,8">

            <!-- 状态卡片 -->
            <Border x:Name="BdrStatus" CornerRadius="8" Padding="14,12"
                    BorderThickness="1" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtStatusIcon" Text="⚠" FontSize="26"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtStatusTitle" Text="检测状态"
                                   FontSize="13" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtStatusDesc" Text="状态描述..."
                                   FontSize="11" Foreground="{DynamicResource SecondaryText}"
                                   TextWrapping="Wrap" LineHeight="17"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 文件路径 + 手动浏览 -->
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="108"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource GridHover}"
                        BorderBrush="{DynamicResource BtnBorder}" BorderThickness="1" CornerRadius="6">
                    <TextBlock x:Name="TxtSelectedFile"
                               Text="（自动检测 AutoCAD 剪贴板文件）"
                               FontSize="11" Foreground="{DynamicResource SecondaryText}"
                               VerticalAlignment="Center"
                               Margin="10,0" TextTrimming="CharacterEllipsis" Height="32"/>
                </Border>
                <Button Grid.Column="2" Content="手动选择文件"
                        FontSize="12" Height="32"
                        Style="{StaticResource FlatButton}"
                        Padding="6,0"
                        Click="BtnBrowse_Click"/>
            </Grid>

            <!-- 导入参数标题 -->
            <TextBlock Text="导入参数设置" FontSize="13" FontWeight="Bold"
                       Foreground="{DynamicResource AccentColor}" Margin="0,0,0,12"/>

            <!-- 导入单位 -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="88"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="导入单位：" VerticalAlignment="Center"
                           FontSize="13" Foreground="#5A5040"/>
                <Border Grid.Column="1" Background="{DynamicResource GridHover}" BorderBrush="{DynamicResource BtnBorder}"
                        BorderThickness="1" CornerRadius="5">
                    <ComboBox x:Name="CboUnits" SelectedIndex="1"
                              Background="Transparent" BorderThickness="0"
                              Foreground="{DynamicResource PrimaryText}" FontSize="13" Height="32">
                        <ComboBoxItem>自动检测</ComboBoxItem>
                        <ComboBoxItem>毫米 (mm)</ComboBoxItem>
                        <ComboBoxItem>厘米 (cm)</ComboBoxItem>
                        <ComboBoxItem>分米 (dm)</ComboBoxItem>
                        <ComboBoxItem>米 (m)</ComboBoxItem>
                        <ComboBoxItem>英寸 (inch)</ComboBoxItem>
                        <ComboBoxItem>英尺 (foot)</ComboBoxItem>
                    </ComboBox>
                </Border>
            </Grid>

            <!-- 颜色模式 -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="88"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="颜色模式：" VerticalAlignment="Center"
                           FontSize="13" Foreground="#5A5040"/>
                <Border Grid.Column="1" Background="{DynamicResource GridHover}" BorderBrush="{DynamicResource BtnBorder}"
                        BorderThickness="1" CornerRadius="5">
                    <ComboBox x:Name="CboColors" SelectedIndex="0"
                              Background="Transparent" BorderThickness="0"
                              Foreground="{DynamicResource PrimaryText}" FontSize="13" Height="32">
                        <ComboBoxItem>保留色彩</ComboBoxItem>
                        <ComboBoxItem>黑白模式</ComboBoxItem>
                        <ComboBoxItem>反色模式</ComboBoxItem>
                    </ComboBox>
                </Border>
            </Grid>

            <!-- 定位方式 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="88"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="定位方式：" VerticalAlignment="Center"
                           FontSize="13" Foreground="#5A5040"/>
                <Border Grid.Column="1" Background="{DynamicResource GridHover}" BorderBrush="{DynamicResource BtnBorder}"
                        BorderThickness="1" CornerRadius="5">
                    <ComboBox x:Name="CboPlacement" SelectedIndex="0"
                              Background="Transparent" BorderThickness="0"
                              Foreground="{DynamicResource PrimaryText}" FontSize="13" Height="32">
                        <ComboBoxItem>原点到原点</ComboBoxItem>
                        <ComboBoxItem>中心到中心</ComboBoxItem>
                    </ComboBox>
                </Border>
            </Grid>

            <!-- 仅当前视口复制 -->
            <Grid Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="88"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="ChkThisViewOnly" Grid.Column="1"
                          Content="仅当前视口复制 (This View Only)"
                          IsChecked="True"
                          Foreground="#5A5040" FontSize="13" VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>

        <!-- 底部操作栏 -->
        <Border Grid.Row="2" Background="{DynamicResource BottomBarBg}"
                BorderThickness="0,1,0,0" BorderBrush="{DynamicResource WindowBorder}">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="数据从 AutoCAD 剪贴板临时缓存提取"
                           VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource SecondaryText}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="重新检测" Style="{StaticResource FlatButton}"
                            Click="BtnRedetect_Click" Margin="0,0,10,0"/>
                    <Button x:Name="BtnConfirm" Content="确定粘贴"
                            Style="{StaticResource AccentButton}"
                            Click="BtnConfirm_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
