<Window x:Class="YangTools.Revit.UI.TextModifierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="文本修改器"
        Height="550"
        Width="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource PrimaryText}"
        FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI"
        AllowsTransparency="True"
        WindowStyle="None"
        BorderThickness="1"
        BorderBrush="{DynamicResource WindowBorder}"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <Style x:Key="FlatButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource BtnBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BtnBorder}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border" CornerRadius="4" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BtnHover}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource BtnBorder}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BtnHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource TitleText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border" CornerRadius="5" Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border" CornerRadius="3" Background="{TemplateBinding Background}" Padding="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource DangerBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RadioButtonStyle" TargetType="{x:Type RadioButton}">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CheckBoxStyle" TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="itemBd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="itemBd" Property="Background" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBd" Property="Background" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="54"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="{DynamicResource TitleBarGradient}">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="文本修改器" FontWeight="Bold" FontSize="17" Foreground="#FFFFFF"/>
                    <TextBlock Text="查找替换与批量格式化文本" FontSize="11" Foreground="{DynamicResource TitleText}" Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Width="30" Height="30" Content="×" FontSize="18" FontWeight="Bold" Style="{StaticResource CloseButtonStyle}" Click="CloseButton_Click"/>
            </Grid>
        </Border>

        <!-- 内容区域 -->
        <Grid Grid.Row="1" Margin="20,15,20,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 作用范围 -->
            <Border Grid.Row="0" Background="{DynamicResource PanelBg}" BorderThickness="1" BorderBrush="{DynamicResource BtnBorder}" CornerRadius="4" Padding="15,10" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="作用范围" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource SecondaryText}"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="RbScopeSelection" Content="当前选中" Style="{StaticResource RadioButtonStyle}" IsChecked="True"/>
                        <RadioButton x:Name="RbScopeView" Content="当前视图" Style="{StaticResource RadioButtonStyle}"/>
                        <RadioButton x:Name="RbScopeProject" Content="整个项目" Style="{StaticResource RadioButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 模式选择 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                <RadioButton x:Name="RbModeFindReplace" Content="查找/替换" Style="{StaticResource RadioButtonStyle}" IsChecked="True" Checked="Mode_Changed"/>
                <RadioButton x:Name="RbModeFormat" Content="格式化" Style="{StaticResource RadioButtonStyle}" Checked="Mode_Changed"/>
            </StackPanel>

            <!-- 查找替换面板 -->
            <Border x:Name="PanelFindReplace" Grid.Row="2" Background="{DynamicResource PanelBg}" BorderThickness="1" BorderBrush="{DynamicResource BtnBorder}" CornerRadius="4" Padding="15,15" Visibility="Visible">
                <StackPanel>
                    <TextBlock Text="查找内容：" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtFind" Height="32" Padding="5" Background="{DynamicResource GridHover}" BorderBrush="{DynamicResource BtnBorder}" BorderThickness="1" Margin="0,0,0,15"/>

                    <TextBlock Text="替换为：" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtReplace" Height="32" Padding="5" Background="{DynamicResource GridHover}" BorderBrush="{DynamicResource BtnBorder}" BorderThickness="1" Margin="0,0,0,15"/>

                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="ChkMatchCase" Content="区分大小写" Style="{StaticResource CheckBoxStyle}"/>
                        <CheckBox x:Name="ChkWholeWord" Content="全字匹配" Style="{StaticResource CheckBoxStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 格式化面板 -->
            <Border x:Name="PanelFormat" Grid.Row="2" Background="{DynamicResource PanelBg}" BorderThickness="1" BorderBrush="{DynamicResource BtnBorder}" CornerRadius="4" Padding="15,15" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <ComboBox x:Name="CmbFormats" Width="200" Height="32" Background="{DynamicResource GridHover}" BorderBrush="{DynamicResource BtnBorder}" Padding="5" Margin="0,0,10,0"/>
                        <Button Content="添 加" Style="{StaticResource FlatButton}" Width="70" Click="BtnAddFormat_Click"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ListBox x:Name="LstOperations" Grid.Column="0" Background="{DynamicResource GridHover}" BorderBrush="{DynamicResource BtnBorder}" SelectionMode="Single" Margin="0,0,10,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" Padding="5"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Column="1" Width="80">
                            <Button Content="上 移" Style="{StaticResource FlatButton}" Margin="0,0,0,10" Click="BtnMoveUp_Click"/>
                            <Button Content="下 移" Style="{StaticResource FlatButton}" Margin="0,0,0,10" Click="BtnMoveDown_Click"/>
                            <Button Content="移 除" Style="{StaticResource FlatButton}" Click="BtnRemove_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

        </Grid>

        <!-- 底部操作栏 -->
        <Border Grid.Row="2" Background="{DynamicResource BottomBarBg}" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BtnBorder}">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="TxtStatus" VerticalAlignment="Center" Foreground="{DynamicResource SuccessColor}" FontSize="13" FontWeight="Medium"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="取  消" Style="{StaticResource FlatButton}" Click="CloseButton_Click" Margin="0,0,10,0"/>
                    <Button x:Name="BtnConfirm" Content="执  行" Style="{StaticResource AccentButton}" Click="BtnExecute_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
