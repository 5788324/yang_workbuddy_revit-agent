<Window x:Class="YangTools.Revit.UI.ViewGraphicCleanerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="视图图形覆盖清理" Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True" WindowStyle="None" Background="Transparent"
        Loaded="Window_Loaded">
    
    <Window.Resources>
        <!-- Styles for Chang'an theme -->
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#3A3028"/>
        </Style>
        
        <Style x:Key="TitleText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#A0734A"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#8A5E38"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="RegularButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#E8DFD0"/>
            <Setter Property="Foreground" Value="#3A3028"/>
            <Setter Property="BorderBrush" Value="#C8B8A0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DDD0C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox Style -->
        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="#3A3028"/>
        </Style>
    </Window.Resources>

    <Border Background="#FAF6F0" BorderBrush="#D5C8B8" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" CornerRadius="7,7,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#8B6D4C" Offset="0.0" />
                        <GradientStop Color="#C4A67A" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <TextBlock Text="视图图形覆盖清理器" Style="{StaticResource TitleText}" VerticalAlignment="Center" Margin="15,0,0,0"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Width="40" Height="40" Click="CloseButton_Click" Background="Transparent" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border x:Name="bg" Background="Transparent" CornerRadius="0,7,0,0">
                                    <Path Data="M 12,12 L 28,28 M 28,12 L 12,28" Stroke="#FFFFFF" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#C05040"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Toolbar -->
            <Border Grid.Row="1" Background="#F0EAE0" Padding="15,10" BorderBrush="#C8B8A0" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Content="全选" Style="{StaticResource RegularButton}" Click="SelectAll_Click"/>
                    <Button Grid.Column="2" Content="反选" Style="{StaticResource RegularButton}" Click="InvertSelection_Click"/>
                    <Button Grid.Column="4" Content="计算选中视图预估数量" Style="{StaticResource RegularButton}" Click="CalculateSelected_Click"/>
                    
                    <!-- Search box -->
                    <Border Grid.Column="6" Background="#F5F0E8" BorderBrush="#C8B8A0" BorderThickness="1" CornerRadius="4">
                        <Grid>
                            <TextBlock x:Name="SearchPlaceholder" Text="搜索视图名称..." Foreground="#8A7A68" Margin="10,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0" Margin="5,0" VerticalContentAlignment="Center" TextChanged="SearchBox_TextChanged"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- List Area -->
            <Grid Grid.Row="2" Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Headers -->
                <Grid Grid.Row="0" Margin="5,0,20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="视图名称" FontWeight="Bold" Foreground="#8A7A68" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="视图类型" FontWeight="Bold" Foreground="#8A7A68" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="被覆盖元素预估数量" FontWeight="Bold" Foreground="#8A7A68" VerticalAlignment="Center"/>
                </Grid>
                
                <!-- ListBox -->
                <ListBox x:Name="ViewsList" Grid.Row="1" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="{x:Type ListBoxItem}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="5,8"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                        <Border x:Name="Bd" Background="#F0EAE0" CornerRadius="4">
                                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#E8DFD0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding ViewName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip="{Binding ViewName}"/>
                                <TextBlock Grid.Column="2" Text="{Binding ViewTypeName}" VerticalAlignment="Center" Foreground="#8A7A68"/>
                                <TextBlock Grid.Column="3" Text="{Binding OverrideCount}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Bottom Bar -->
            <Border Grid.Row="3" Background="#EDE6DA" CornerRadius="0,0,7,7" BorderBrush="#C8B8A0" BorderThickness="0,1,0,0" Padding="15,0">
                <Grid>
                    <TextBlock x:Name="StatusText" Text="准备就绪" VerticalAlignment="Center" Foreground="#8A7A68"/>
                    <Button Content="执行清理" Style="{StaticResource ActionButton}" HorizontalAlignment="Right" Width="120" Click="ExecuteClean_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
