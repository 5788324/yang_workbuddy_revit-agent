<Window x:Class="YangTools.Revit.UI.ProjectInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="文件信息"
        Height="700" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource PrimaryText}"
        FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI"
        AllowsTransparency="True"
        WindowStyle="None"
        BorderThickness="1"
        BorderBrush="{DynamicResource WindowBorder}"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- 普通按钮 -->
        <Style x:Key="FlatButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource BtnBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BtnBorder}"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bd" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource BtnHover}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource BtnHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.6"/>
                                <Setter Property="Cursor" Value="Wait"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 强调色按钮 -->
        <Style x:Key="AccentButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bd" CornerRadius="6"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.6"/>
                                <Setter Property="Cursor" Value="Wait"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="56"/>
        </Grid.RowDefinitions>

        <!-- 顶部渐变标题栏 -->
        <Border Grid.Row="0" Background="{DynamicResource TitleBarGradient}">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Text="项目信息" FontWeight="Bold" FontSize="18" Foreground="#FFFFFF"/>
                    <TextBlock Text=" |  文件信息与清理预测" FontSize="13" Foreground="{DynamicResource TitleText}" Margin="8,3,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Width="32" Height="32"
                        Content="✕" FontSize="15" FontWeight="Bold"
                        Foreground="#FFFFFF" Cursor="Hand"
                        Click="CloseButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="closebd" Background="Transparent" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="closebd" Property="Background" Value="{DynamicResource DangerBg}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- 中间卡片式内容 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" BorderThickness="0">
            <StackPanel Margin="22,18">
                <!-- Card 1: 基本信息 -->
                <TextBlock Text="基本信息 (Basic Info)"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentColor}" Margin="0,0,0,8"/>
                <Border Background="{DynamicResource PanelBg}" CornerRadius="8"
                        BorderThickness="1" BorderBrush="{DynamicResource WindowBorder}" Padding="15" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="5" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Revit Version -->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Revit 版本" FontSize="11" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtRevitVersion" Text="加载中..." FontSize="13" Foreground="{DynamicResource PrimaryText}"/>
                        </StackPanel>

                        <!-- File Name -->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="文件名称" FontSize="11" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtFileName" Text="加载中..." FontSize="13" Foreground="{DynamicResource PrimaryText}"/>
                        </StackPanel>

                        <!-- File Path -->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="本地文档路径" FontSize="11" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtDocPath" Text="加载中..." FontSize="13"
                                         Background="Transparent" BorderThickness="0" IsReadOnly="True"
                                         Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap" Margin="0,0,10,0"/>
                                <Button Grid.Column="1" Content="复制/Copy" Style="{StaticResource FlatButton}" Padding="8,4" FontSize="11" Click="CopyPath_Click" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <!-- 中心文件路径 -->
                        <StackPanel x:Name="PanelCentralPath" Margin="0,0,0,10" Visibility="Collapsed">
                            <TextBlock Text="中心模型路径" FontSize="11" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtCentralPath" Text="加载中..." FontSize="13"
                                         Background="Transparent" BorderThickness="0" IsReadOnly="True"
                                         Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap" Margin="0,0,10,0"/>
                                <Button Grid.Column="1" Content="复制/Copy" Style="{StaticResource FlatButton}" Padding="8,4" FontSize="11" Click="CopyCentralPath_Click" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <!-- 分割线 -->
                        <Rectangle Fill="{DynamicResource WindowBorder}" Height="1" Margin="0,4,0,10"/>

                        <!-- 文件大小和修改时间 -->
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="当前文件大小" FontSize="11" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtFileSize" Text="0 MB" FontSize="14"
                                           FontWeight="Medium" Foreground="{DynamicResource PrimaryText}"/>
                            </StackPanel>

                            <Rectangle Grid.Column="1" Fill="{DynamicResource WindowBorder}" Width="1"/>

                            <StackPanel Grid.Column="2" Margin="15,0,0,0">
                                <TextBlock Text="最后修改时间" FontSize="11" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtLastModified" Text="-" FontSize="14"
                                           FontWeight="Medium" Foreground="{DynamicResource PrimaryText}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Card 2: 瘦身预估 -->
                <TextBlock Text="瘦身预估 (Purge Estimation)"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentColor}" Margin="0,0,0,8"/>
                <Border Background="{DynamicResource PanelBg}" CornerRadius="8"
                        BorderThickness="1" BorderBrush="{DynamicResource WindowBorder}" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="5" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="可清理的未使用图元数" FontSize="11" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtUnusedCount" Text="加载中..." FontSize="14"
                                           FontWeight="Medium" Foreground="{DynamicResource WarningColor}"/>
                            </StackPanel>

                            <Rectangle Grid.Column="1" Fill="{DynamicResource WindowBorder}" Width="1"/>

                            <StackPanel Grid.Column="2" Margin="15,0,0,0">
                                <TextBlock Text="当前大小" FontSize="11" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtCurrentSizeCard2" Text="-" FontSize="14"
                                           FontWeight="Medium" Foreground="{DynamicResource PrimaryText}"/>
                            </StackPanel>
                        </Grid>

                        <Rectangle Fill="{DynamicResource WindowBorder}" Height="1" Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="清理后预计大小" FontSize="11" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtPurgedSize" Text="-" FontSize="14"
                                           FontWeight="Medium" Foreground="{DynamicResource SuccessColor}"/>
                            </StackPanel>

                            <Rectangle Grid.Column="1" Fill="{DynamicResource WindowBorder}" Width="1"/>

                            <StackPanel Grid.Column="2" Margin="15,0,0,0">
                                <TextBlock Text="预计可节省空间" FontSize="11" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtSavedSize" Text="-" FontSize="14"
                                           FontWeight="Medium" Foreground="{DynamicResource SuccessColor}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 底部操作栏 -->
        <Border Grid.Row="2" Background="{DynamicResource BottomBarBg}" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource WindowBorder}">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus" Text="就绪"
                           VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource SecondaryText}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnCalculatePurge" Content="计算清理后大小" Style="{StaticResource AccentButton}"
                            Click="BtnCalculatePurge_Click" Margin="0,0,10,0"/>
                    <Button Content="关闭" Style="{StaticResource FlatButton}"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
