<!--
    YangTools 主题 - 专业蓝灰 (Professional Blue-Gray)
    专业的蓝灰色调，适合企业环境
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== 基础色板 ===== -->
    <Color x:Key="Color_WindowBg">#F0F4F8</Color>
    <Color x:Key="Color_WindowBorder">#C0CCD8</Color>
    <Color x:Key="Color_PanelBg">#E4ECF2</Color>
    <Color x:Key="Color_SidePanelBg">#DCE4EC</Color>
    <Color x:Key="Color_BottomBarBg">#E8EEF4</Color>
    
    <Color x:Key="Color_PrimaryText">#1E2D3D</Color>
    <Color x:Key="Color_SecondaryText">#607080</Color>
    <Color x:Key="Color_DisabledText">#98A8B8</Color>
    
    <Color x:Key="Color_Accent">#2C5F8A</Color>
    <Color x:Key="Color_AccentHover">#1E4870</Color>
    <Color x:Key="Color_AccentLight">#4A80B0</Color>
    
    <Color x:Key="Color_BtnBg">#E0E8F0</Color>
    <Color x:Key="Color_BtnBorder">#B0C0D0</Color>
    <Color x:Key="Color_BtnHover">#D0DAE4</Color>
    <Color x:Key="Color_BtnPressed">#BEC8D4</Color>
    <Color x:Key="Color_BtnText">#1E2D3D</Color>
    
    <Color x:Key="Color_DangerBg">#C05040</Color>
    <Color x:Key="Color_DangerHover">#A04030</Color>
    <Color x:Key="Color_Success">#3A8040</Color>
    <Color x:Key="Color_Warning">#C09030</Color>
    <Color x:Key="Color_Info">#2C5F8A</Color>
    
    <Color x:Key="Color_TitleBarStart">#1E3A54</Color>
    <Color x:Key="Color_TitleBarEnd">#2C5F8A</Color>
    <Color x:Key="Color_TitleText">#FFFFFF</Color>
    <Color x:Key="Color_TitleCloseHover">#C05040</Color>

    <Color x:Key="Color_InputBg">#FFFFFF</Color>
    <Color x:Key="Color_InputBorder">#B0C0D0</Color>
    <Color x:Key="Color_InputFocusBorder">#2C5F8A</Color>
    <Color x:Key="Color_InputText">#1E2D3D</Color>
    <Color x:Key="Color_Placeholder">#98A8B8</Color>
    
    <Color x:Key="Color_GridHeaderBg">#E4ECF2</Color>
    <Color x:Key="Color_GridRowBg">#FFFFFF</Color>
    <Color x:Key="Color_GridAltRowBg">#F6F9FB</Color>
    <Color x:Key="Color_GridLine">#D0DAE4</Color>
    <Color x:Key="Color_GridSelected">#D0DEE8</Color>
    <Color x:Key="Color_GridHover">#ECF2F6</Color>

    <!-- ===== 笔刷 ===== -->
    <SolidColorBrush x:Key="WindowBg" Color="{DynamicResource Color_WindowBg}"/>
    <SolidColorBrush x:Key="WindowBorder" Color="{DynamicResource Color_WindowBorder}"/>
    <SolidColorBrush x:Key="PanelBg" Color="{DynamicResource Color_PanelBg}"/>
    <SolidColorBrush x:Key="SidePanelBg" Color="{DynamicResource Color_SidePanelBg}"/>
    <SolidColorBrush x:Key="BottomBarBg" Color="{DynamicResource Color_BottomBarBg}"/>
    <SolidColorBrush x:Key="PrimaryText" Color="{DynamicResource Color_PrimaryText}"/>
    <SolidColorBrush x:Key="SecondaryText" Color="{DynamicResource Color_SecondaryText}"/>
    <SolidColorBrush x:Key="DisabledText" Color="{DynamicResource Color_DisabledText}"/>
    <SolidColorBrush x:Key="AccentColor" Color="{DynamicResource Color_Accent}"/>
    <SolidColorBrush x:Key="AccentHover" Color="{DynamicResource Color_AccentHover}"/>
    <SolidColorBrush x:Key="AccentLight" Color="{DynamicResource Color_AccentLight}"/>
    <SolidColorBrush x:Key="BtnBg" Color="{DynamicResource Color_BtnBg}"/>
    <SolidColorBrush x:Key="BtnBorder" Color="{DynamicResource Color_BtnBorder}"/>
    <SolidColorBrush x:Key="BtnHover" Color="{DynamicResource Color_BtnHover}"/>
    <SolidColorBrush x:Key="BtnPressed" Color="{DynamicResource Color_BtnPressed}"/>
    <SolidColorBrush x:Key="BtnText" Color="{DynamicResource Color_BtnText}"/>
    <SolidColorBrush x:Key="DangerBg" Color="{DynamicResource Color_DangerBg}"/>
    <SolidColorBrush x:Key="DangerHover" Color="{DynamicResource Color_DangerHover}"/>
    <SolidColorBrush x:Key="SuccessColor" Color="{DynamicResource Color_Success}"/>
    <SolidColorBrush x:Key="WarningColor" Color="{DynamicResource Color_Warning}"/>
    <SolidColorBrush x:Key="InfoColor" Color="{DynamicResource Color_Info}"/>
    <SolidColorBrush x:Key="TitleBarStart" Color="{DynamicResource Color_TitleBarStart}"/>
    <SolidColorBrush x:Key="TitleBarEnd" Color="{DynamicResource Color_TitleBarEnd}"/>
    <SolidColorBrush x:Key="TitleText" Color="{DynamicResource Color_TitleText}"/>
    <SolidColorBrush x:Key="TitleCloseHover" Color="{DynamicResource Color_TitleCloseHover}"/>
    <SolidColorBrush x:Key="InputBg" Color="{DynamicResource Color_InputBg}"/>
    <SolidColorBrush x:Key="InputBorder" Color="{DynamicResource Color_InputBorder}"/>
    <SolidColorBrush x:Key="InputFocusBorder" Color="{DynamicResource Color_InputFocusBorder}"/>
    <SolidColorBrush x:Key="InputText" Color="{DynamicResource Color_InputText}"/>
    <SolidColorBrush x:Key="Placeholder" Color="{DynamicResource Color_Placeholder}"/>
    <SolidColorBrush x:Key="GridHeaderBg" Color="{DynamicResource Color_GridHeaderBg}"/>
    <SolidColorBrush x:Key="GridRowBg" Color="{DynamicResource Color_GridRowBg}"/>
    <SolidColorBrush x:Key="GridAltRowBg" Color="{DynamicResource Color_GridAltRowBg}"/>
    <SolidColorBrush x:Key="GridLine" Color="{DynamicResource Color_GridLine}"/>
    <SolidColorBrush x:Key="GridSelected" Color="{DynamicResource Color_GridSelected}"/>
    <SolidColorBrush x:Key="GridHover" Color="{DynamicResource Color_GridHover}"/>

    <!-- Title Bar Gradient -->
    <LinearGradientBrush x:Key="TitleBarGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#1E3A54" Offset="0"/>
        <GradientStop Color="#2C5F8A" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
