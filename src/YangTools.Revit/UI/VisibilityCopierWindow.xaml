<Window x:Class="YangTools.Revit.UI.VisibilityCopierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="可见性拷贝" Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True" WindowStyle="None"
        Background="Transparent">
    
    <Window.Resources>
        <ResourceDictionary>
            <Style x:Key="ChanganTitleBar" TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource TitleBarGradient}"/>
            </Style>

            <Style TargetType="{x:Type ComboBoxItem}">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="10,7"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                            <Border x:Name="itemBd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="itemBd" Property="Background" Value="{DynamicResource AccentColor}"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="itemBd" Property="Background" Value="#7A5535"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{DynamicResource WindowBg}" BorderBrush="{DynamicResource WindowBorder}" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Style="{StaticResource ChanganTitleBar}" CornerRadius="7,7,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="可见性拷贝" Foreground="#FFFFFF" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Margin="15,0,0,0"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Width="30" Height="30" Background="Transparent" BorderThickness="0" Click="CloseButton_Click" ToolTip="关闭">
                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="15">
                                    <TextBlock Text="✕" Foreground="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{DynamicResource DangerBg}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Source View -->
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="源视图:" Foreground="{DynamicResource SecondaryText}" FontSize="14" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbSourceView" Height="30" Background="{DynamicResource GridHover}" BorderBrush="{DynamicResource BtnBorder}" FontSize="13" SelectionChanged="CmbSourceView_SelectionChanged">
                        <!-- Items source will be populated in code behind -->
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource PrimaryText}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Copy Options -->
                <Border Grid.Column="1" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource WindowBorder}" BorderThickness="1" CornerRadius="4" Margin="10,0,10,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="复制选项:" Foreground="{DynamicResource SecondaryText}" FontSize="14" Margin="0,0,0,10" FontWeight="Bold"/>
                        <CheckBox x:Name="ChkModelCategories" Content="模型类别" IsChecked="True" Foreground="{DynamicResource PrimaryText}" Margin="0,5"/>
                        <CheckBox x:Name="ChkAnnotationCategories" Content="注释类别" IsChecked="True" Foreground="{DynamicResource PrimaryText}" Margin="0,5"/>
                        <CheckBox x:Name="ChkAnalyticalCategories" Content="分析模型类别" Foreground="{DynamicResource PrimaryText}" Margin="0,5"/>
                        <CheckBox x:Name="ChkImportCategories" Content="导入的类别" Foreground="{DynamicResource PrimaryText}" Margin="0,5"/>
                        <CheckBox x:Name="ChkFilters" Content="过滤器" IsChecked="True" Foreground="{DynamicResource PrimaryText}" Margin="0,5"/>
                        <CheckBox x:Name="ChkWorksets" Content="工作集" Foreground="{DynamicResource PrimaryText}" Margin="0,5"/>
                        <CheckBox x:Name="ChkRvtLinks" Content="Revit链接" Foreground="{DynamicResource PrimaryText}" Margin="0,5"/>
                    </StackPanel>
                </Border>

                <!-- Target Views -->
                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                    <TextBlock Text="目标视图:" Foreground="{DynamicResource SecondaryText}" FontSize="14" Margin="0,0,0,5"/>
                    <Border Background="{DynamicResource GridHover}" BorderBrush="{DynamicResource BtnBorder}" BorderThickness="1" CornerRadius="4" Height="320">
                        <ListBox x:Name="LstTargetViews" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Foreground="{DynamicResource PrimaryText}" Margin="0,5"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Button Content="全选" Width="60" Height="25" Margin="0,0,10,0" Click="SelectAll_Click" Background="{DynamicResource BtnBg}" BorderBrush="{DynamicResource BtnBorder}" Foreground="{DynamicResource PrimaryText}"/>
                        <Button Content="全不选" Width="60" Height="25" Click="SelectNone_Click" Background="{DynamicResource BtnBg}" BorderBrush="{DynamicResource BtnBorder}" Foreground="{DynamicResource PrimaryText}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Bottom Bar -->
            <Border Grid.Row="2" Background="{DynamicResource BottomBarBg}" BorderBrush="{DynamicResource WindowBorder}" BorderThickness="0,1,0,0" CornerRadius="0,0,7,7">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Button Content="取消" Width="100" Height="35" Margin="0,0,15,0" Click="CloseButton_Click" Background="{DynamicResource BtnBg}" BorderBrush="{DynamicResource BtnBorder}" Foreground="{DynamicResource PrimaryText}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4">
                                    <TextBlock Text="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="拷贝" Width="100" Height="35" Click="CopyButton_Click" Background="{DynamicResource AccentColor}" BorderBrush="Transparent" Foreground="#FFFFFF" FontWeight="Bold" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4">
                                    <TextBlock Text="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}" FontWeight="{TemplateBinding FontWeight}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
