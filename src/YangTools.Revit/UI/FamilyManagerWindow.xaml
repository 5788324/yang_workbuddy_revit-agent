<Window x:Class="YangTools.Revit.UI.FamilyManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="族文档管理 (Family Manager)" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True" WindowStyle="None"
        Background="Transparent">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="SharedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

        <Style TargetType="{x:Type DataGrid}" BasedOn="{StaticResource SharedDataGridStyle}">
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource SharedDataGridColumnHeaderStyle}">
        </Style>

        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BtnBg}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource WindowBorder}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CategoryGroupStyle" TargetType="{x:Type GroupItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GroupItem}">
                        <StackPanel>
                            <Border Background="{DynamicResource BtnBorder}" Padding="10,5">
                                <TextBlock FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" Text="{Binding Name}" />
                            </Border>
                            <ItemsPresenter />
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource WindowBg}" BorderBrush="{StaticResource WindowBorder}" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border CornerRadius="7,7,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Background="{DynamicResource TitleBarGradient}">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                        <TextBlock Text="族文档管理" Foreground="#FFFFFF" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text=" Family Manager" Foreground="{DynamicResource PanelBg}" FontSize="14" Margin="5,2,0,0"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Width="30" Height="30" Background="Transparent" BorderThickness="0" Click="CloseButton_Click" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border x:Name="bg" Background="Transparent" CornerRadius="15">
                                    <Path Data="M 10,10 L 20,20 M 20,10 L 10,20" Stroke="#FFFFFF" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="{DynamicResource DangerBg}"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Family List -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Background="{StaticResource PanelBg}" BorderBrush="{StaticResource WindowBorder}" BorderThickness="0,0,0,1" Padding="10">
                        <StackPanel>
                            <TextBlock Text="类别过滤 (Category):" Foreground="{StaticResource SecondaryText}" Margin="0,0,0,5"/>
                            <ComboBox x:Name="CategoryFilterComboBox" Margin="0,0,0,10" SelectionChanged="FilterChanged"/>
                            <TextBlock Text="搜索族 (Search):" Foreground="{StaticResource SecondaryText}" Margin="0,0,0,5"/>
                            <TextBox x:Name="SearchBox" Padding="5" TextChanged="FilterChanged"/>
                        </StackPanel>
                    </Border>
                    
                    <ListBox x:Name="FamilyListBox" Grid.Row="1" Background="Transparent" BorderThickness="0" SelectionChanged="FamilyListBox_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.GroupStyle>
                            <GroupStyle ContainerStyle="{StaticResource CategoryGroupStyle}" />
                        </ListBox.GroupStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding FamilyName}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TypeCount, StringFormat='({0})'}" Foreground="{StaticResource SecondaryText}" FontSize="11" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Divider -->
                <Rectangle Grid.Column="1" Fill="{StaticResource WindowBorder}"/>

                <!-- Right Panel: Types DataGrid & Tools -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource PanelBg}" BorderBrush="{StaticResource WindowBorder}" BorderThickness="0,0,0,1" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SelectedFamilyTitle" Text="请在左侧选择一个族" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource PrimaryText}" VerticalAlignment="Center"/>
                            <Button x:Name="RenameFamilyBtn" Grid.Column="1" ToolTip="重命名族 (Rename Family)" Style="{StaticResource IconButton}" Click="RenameFamily_Click" Visibility="Collapsed">
                                <TextBlock Text="&#xE8AC;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                            </Button>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="TypeDataGrid" Grid.Row="1" Margin="10" CellEditEnding="TypeDataGrid_CellEditEnding" Visibility="Collapsed">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="类型名称 (Type Name)" Binding="{Binding TypeName}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel x:Name="EmptyStatePanel" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="请从左侧选择一个族" FontSize="18" Foreground="{StaticResource SecondaryText}" HorizontalAlignment="Center"/>
                        <TextBlock Text="每个族类型都是一个独立的明细表" FontSize="13" Foreground="{StaticResource SecondaryText}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="2" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource WindowBorder}" BorderThickness="0,1,0,0" Padding="10,5">
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button ToolTip="重置参数列 (Reset Columns)" Style="{StaticResource IconButton}" Click="ResetColumns_Click">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                            </Button>
                            <Button ToolTip="复制类型 (Duplicate)" Style="{StaticResource IconButton}" Click="Duplicate_Click">
                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                            </Button>
                            <Button ToolTip="更改类别 (Change Category)" Style="{StaticResource IconButton}" Click="ChangeCategory_Click">
                                <TextBlock Text="&#xE8B9;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                            </Button>
                            <Button ToolTip="批量重命名 (Batch Rename)" Style="{StaticResource IconButton}" Click="BatchRename_Click">
                                <TextBlock Text="&#xE8AC;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                            </Button>
                            <Button ToolTip="导出 RFA (Export RFA)" Style="{StaticResource IconButton}" Click="ExportRfa_Click" Foreground="{DynamicResource SuccessColor}">
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                            </Button>
                            <Button ToolTip="导出 Excel" Style="{StaticResource IconButton}" Click="ExportExcel_Click">
                                <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                            </Button>
                            <Button ToolTip="导入 Excel" Style="{StaticResource IconButton}" Click="ImportExcel_Click" Foreground="{DynamicResource AccentColor}">
                                <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                            </Button>
                            <Button ToolTip="删除类型/族 (Delete)" Style="{StaticResource IconButton}" Click="Delete_Click" Foreground="{DynamicResource DangerBg}">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                            </Button>
                        </WrapPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
