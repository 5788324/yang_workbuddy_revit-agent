<Window x:Class="YangTools.Revit.UI.ChineseCheckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ПоДүЦРОДәмІй"
        Height="650" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource PrimaryText}"
        FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI"
        AllowsTransparency="True"
        WindowStyle="None"
        BorderThickness="1"
        BorderBrush="{DynamicResource WindowBorder}"
        MouseDown="Window_MouseDown">

    <Window.Resources>

        <!-- ЖХНЁ°өЕӨ -->
        <Style x:Key="FlatButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource BtnBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BtnBorder}"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bd" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource BtnHover}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource BtnPressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource DisabledText}"/>
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SidePanelBg}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource BtnBorder}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Зүµч°өЕӨӘЁН­Й«Ә© -->
        <Style x:Key="AccentButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource TitleText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="18,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bd" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- №Ш±Х°өЕӨӘЁ±кМвАёУГӘ© -->
        <Style x:Key="TitleCloseButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TitleText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource DangerBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListBox СщКҢ -->
        <Style x:Key="CheckListBox" TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="{DynamicResource GridHover}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BtnBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        </Style>

        <!-- ListBoxItem СщКҢ -->
        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="itemBd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="itemBd" Property="Background" Value="{DynamicResource BtnBg}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBd" Property="Background" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TitleText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- ===== ±кМвАё ===== -->
        <Border Grid.Row="0" Background="{DynamicResource TitleBarGradient}">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Text="ПоДүЦРОДәмІй" FontWeight="Bold" FontSize="17" Foreground="{DynamicResource TitleText}"/>
                    <TextBlock Text="  |  ЙЁГиЧеҰұІОКэҰұЧұКНЦРµДЦРОДЧЦ·ы" FontSize="12"
                               Foreground="{DynamicResource TitleText}" Margin="6,3,0,0" VerticalAlignment="Bottom"/>
                </StackPanel>
                <Button Grid.Column="1" Width="32" Height="32"
                        Content="?" FontSize="15" FontWeight="Bold"
                        Style="{StaticResource TitleCloseButton}"
                        Click="CloseButton_Click"/>
            </Grid>
        </Border>

        <!-- ===== ЙП°лЗшӘЁЧе/АаРН/ІДЦК/ЧұКН + ЧеКµАэӘ© ===== -->
        <Grid Grid.Row="1" Margin="14,10,14,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ЧуЙПӘғЧе/ЧеАаРН/ІДЦК/ЧұКН -->
            <Border Grid.Column="0" Background="{DynamicResource PanelBg}" CornerRadius="6" Padding="10,8"
                    BorderBrush="{DynamicResource BtnBorder}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="ЧеҰұЧеАаРНҰұІДЦКҰұЧұКН ҰҒҰҒ өжФЪЦРОДӘғ"
                               FontSize="12" FontWeight="Bold" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,6"/>
                    <ListBox Grid.Row="1" x:Name="ListFamilyTypes"
                             Style="{StaticResource CheckListBox}"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <Button Content="Йңіэ" Style="{StaticResource FlatButton}"
                                Click="BtnDeleteFamilyTypes_Click" Margin="0,0,6,0" Padding="12,5"/>
                        <Button Content="µәіцID" Style="{StaticResource FlatButton}"
                                Click="BtnExportFamilyTypeIds_Click" Padding="12,5"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- УТЙПӘғЧеКµАэІОКэ -->
            <Border Grid.Column="2" Background="{DynamicResource PanelBg}" CornerRadius="6" Padding="10,8"
                    BorderBrush="{DynamicResource BtnBorder}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="ЧеКµАэ ҰҒҰҒ өжФЪЦРОДІОКэӘғ"
                               FontSize="12" FontWeight="Bold" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,6"/>
                    <ListBox Grid.Row="1" x:Name="ListFamilyInstances"
                             Style="{StaticResource CheckListBox}"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <Button Content="Йңіэ" Style="{StaticResource FlatButton}"
                                Click="BtnDeleteInstances_Click" Margin="0,0,6,0" Padding="12,5"/>
                        <Button Content="µәіцID" Style="{StaticResource FlatButton}"
                                Click="BtnExportInstanceIds_Click" Padding="12,5"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== ПВ°лЗшӘЁSharedParameter + ПоДү»·ңіӘ© ===== -->
        <Grid Grid.Row="2" Margin="14,4,14,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ЧуПВӘғПоДүІОКэ -->
            <Border Grid.Column="0" Background="{DynamicResource PanelBg}" CornerRadius="6" Padding="10,8"
                    BorderBrush="{DynamicResource BtnBorder}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="ПоДүІОКэ ҰҒҰҒ өжФЪЦРОДӘғ"
                               FontSize="12" FontWeight="Bold" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,6"/>
                    <ListBox Grid.Row="1" x:Name="ListProjectParams"
                             Style="{StaticResource CheckListBox}"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <Button Content="Йңіэ" Style="{StaticResource FlatButton}"
                                Click="BtnDeleteProjectParams_Click" Margin="0,0,6,0" Padding="12,5"/>
                        <Button Content="µәіцID" Style="{StaticResource FlatButton}"
                                Click="BtnExportProjectParamIds_Click" Padding="12,5"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- УТПВӘғПоДү»·ңіӘЁКУНәГыіЖµИӘ© -->
            <Border Grid.Column="2" Background="{DynamicResource PanelBg}" CornerRadius="6" Padding="10,8"
                    BorderBrush="{DynamicResource BtnBorder}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="ПоДү»·ңіӘЁКУНәГыіЖµИӘ©Әғ"
                               FontSize="12" FontWeight="Bold" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,6"/>
                    <ListBox Grid.Row="1" x:Name="ListProjectEnv"
                             Style="{StaticResource CheckListBox}"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                        <Button Content="Йңіэ" Style="{StaticResource FlatButton}"
                                Click="BtnDeleteProjectEnv_Click" Margin="0,0,6,0" Padding="12,5"/>
                        <Button Content="µәіцID" Style="{StaticResource FlatButton}"
                                Click="BtnExportProjectEnvIds_Click" Padding="12,5"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== µЧІүІЩЧчАё ===== -->
        <Border Grid.Row="3" Background="{DynamicResource BottomBarBg}"
                BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BtnBorder}">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource SecondaryText}"
                           TextWrapping="Wrap" Margin="0,0,10,0"
                           Text="әмІйДЪИЭӘғЛщУРЧе(ғ¬ПµНіЧе)µДЧеГыҰұЧеАаРНГыҰұЧеАа±рГыҰұЧеІОКэГы/ЦµӘ¬ТФә°ПоДүЦРЛщУРОДЧЦЧұКНҰұКУНәГыіЖКЗ·с°ьғ¬ЦРОДҰӘ"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="ІйСҮ/ЛұРВ" Style="{StaticResource FlatButton}"
                            Click="BtnRefresh_Click" Margin="0,0,8,0"/>
                    <Button Content="№Ш±Х" Style="{StaticResource AccentButton}"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
