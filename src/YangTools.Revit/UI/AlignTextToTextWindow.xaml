<Window x:Class="YangTools.Revit.UI.AlignTextToTextWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="对齐到文本" Height="220" Width="280"
        AllowsTransparency="True" WindowStyle="None" WindowStartupLocation="CenterOwner"
        Background="Transparent">

    <Border Background="{DynamicResource WindowBg}" BorderBrush="{DynamicResource WindowBorder}" BorderThickness="1" CornerRadius="4" MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border CornerRadius="3,3,0,0" Background="{DynamicResource TitleBarGradient}">
                <Grid>
                    <TextBlock Text="对齐到文本" Foreground="{DynamicResource TitleText}" VerticalAlignment="Center" Margin="15,0,0,0" FontWeight="Bold"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Width="30" Height="30" 
                            Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TitleText}" FontSize="16"
                            Click="BtnCancel_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border Background="{TemplateBinding Background}" CornerRadius="0,3,0,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource DangerBg}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="20" Background="{DynamicResource PanelBg}">
                <CheckBox x:Name="chkAlignX" Content="对齐 X 坐标 (垂直对齐)" Foreground="{DynamicResource PrimaryText}" IsChecked="True" Margin="0,0,0,10"/>
                <CheckBox x:Name="chkAlignY" Content="对齐 Y 坐标 (水平对齐)" Foreground="{DynamicResource PrimaryText}" IsChecked="False" Margin="0,0,0,10"/>
                <CheckBox x:Name="chkAlignRot" Content="对齐旋转角度" Foreground="{DynamicResource PrimaryText}" IsChecked="True" Margin="0,0,0,0"/>
            </StackPanel>

            <!-- Bottom Bar -->
            <Border Grid.Row="2" Background="{DynamicResource BottomBarBg}" BorderBrush="{DynamicResource BtnBorder}" BorderThickness="0,1,0,0" CornerRadius="0,0,3,3">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,15,0">
                    <Button Content="取消" Width="70" Height="28" Margin="0,0,10,0" Click="BtnCancel_Click"
                            Background="{DynamicResource BtnBg}" BorderBrush="{DynamicResource BtnBorder}" Foreground="{DynamicResource PrimaryText}"/>
                    <Button Content="确定" Width="70" Height="28" Click="BtnOk_Click"
                            Background="{DynamicResource AccentColor}" BorderBrush="{DynamicResource AccentHover}" Foreground="{DynamicResource TitleText}" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
