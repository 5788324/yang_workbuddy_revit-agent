<Window x:Class="YangTools.Revit.UI.NewProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新建项目" Height="220" Width="450"
        WindowStyle="None" AllowsTransparency="True" Background="#2D2D2D" Foreground="#E0E0E0"
        WindowStartupLocation="CenterOwner" Topmost="True">
    <Window.Resources>
        <Style TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#A07A50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B88E5E"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#8C6A45"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid Grid.Row="0" Background="#1E1E1E" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <TextBlock Text="新建微工具项目" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#A07A50" FontWeight="Bold"/>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="20,15,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="项目名称:" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0" Margin="0,0,0,10"/>
            <TextBox x:Name="ProjectNameBox" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10"/>

            <TextBlock Text="文件夹路径:" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0" Margin="0,0,0,10"/>
            <TextBox x:Name="FolderPathBox" Grid.Row="1" Grid.Column="1" Margin="0,0,5,10"/>
            <Button Content="浏览..." Grid.Row="1" Grid.Column="2" Width="60" Height="26" Margin="0,0,0,10" Click="BrowseButton_Click" Background="#444"/>

            <TextBlock Text="(支持任意盘符。若文件夹不存在，将自动创建)" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Foreground="#888" FontSize="11"/>
        </Grid>

        <!-- Bottom Bar -->
        <Border Grid.Row="2" Background="#1E1E1E" BorderThickness="0,1,0,0" BorderBrush="#444">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,15,0">
                <Button Content="取消" Width="80" Height="30" Margin="0,0,10,0" Click="CancelButton_Click" Background="#444"/>
                <Button Content="确认" Width="80" Height="30" Click="ConfirmButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
