<Window x:Class="YangTools.Revit.UI.AssistantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="个人助手" Height="450" Width="600"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True" WindowStyle="None"
        Background="Transparent"
        MouseDown="Window_MouseDown"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border Name="Border" Padding="15,10" Background="#F0EAE0" BorderBrush="#C8B8A0" BorderThickness="1,1,1,0" Margin="2,0,2,0" CornerRadius="4,4,0,0">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FAF6F0"/>
                                <Setter Property="Foreground" Value="#A0734A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="#8A7A68"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#FAF6F0" BorderBrush="#D5C8B8" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Title Bar -->
            <Border Grid.Row="0" CornerRadius="8,8,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#8B6D4C" Offset="0.0"/>
                        <GradientStop Color="#C4A67A" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <TextBlock Text="个人助手 - Assistant" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="15,0" FontWeight="Bold" FontSize="14"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"
                            Width="30" Height="24" Content="✕" Foreground="#FFFFFF" BorderThickness="0"
                            Click="CloseButton_Click" FontSize="14" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C05040"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- TabControl -->
            <TabControl Grid.Row="1" Margin="10" Background="Transparent" BorderBrush="#C8B8A0" BorderThickness="0,1,0,0">
                <TabItem Header="Greeting">
                    <Grid Background="#F0EAE0" Margin="0,10,0,0">
                        <TextBlock x:Name="TxtGreeting" Text="Greeting Placeholder" Foreground="#3A3028" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </TabItem>
                <TabItem Header="Version &amp; Updates">
                    <Grid Background="#F0EAE0" Margin="0,10,0,0">
                        <StackPanel Margin="20">
                            <TextBlock Text="版本：1.0" Foreground="#3A3028" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                            <TextBlock Text="更新日志：" Foreground="#8A7A68" FontSize="14" Margin="0,0,0,5"/>
                            <TextBlock Text="• 全新设计的长安主题界面&#x0A;• 优化了内部性能&#x0A;• 修复了部分已知Bug" Foreground="#3A3028" FontSize="14"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
                <TabItem Header="Disclaimer &amp; Copyright">
                    <Grid Background="#F0EAE0" Margin="0,10,0,0">
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="YangTools 版权所有 © 2024-2026" Foreground="#3A3028" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <TextBlock Text="免责声明：本插件仅供学习与交流使用。开发者不对因使用本插件引起的任何直接或间接损失承担责任。请在实际项目中进行充分测试。" Foreground="#8A7A68" FontSize="13" TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
