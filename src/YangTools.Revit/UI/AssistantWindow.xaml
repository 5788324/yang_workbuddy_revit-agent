<Window x:Class="YangTools.Revit.UI.AssistantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="系统设置" Height="550" Width="680"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True" WindowStyle="None"
        Background="Transparent"
        MouseDown="Window_MouseDown"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border Name="Border" Padding="15,10" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource BtnBorder}" BorderThickness="1,1,1,0" Margin="2,0,2,0" CornerRadius="4,4,0,0">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource WindowBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource WindowBg}" BorderBrush="{DynamicResource WindowBorder}" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Title Bar -->
            <Border Grid.Row="0" CornerRadius="8,8,0,0" Background="{DynamicResource TitleBarGradient}">
                <Grid>
                    <TextBlock Text="系统设置" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="15,0" FontWeight="Bold" FontSize="14"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"
                            Width="30" Height="24" Content="✕" Foreground="#FFFFFF" BorderThickness="0"
                            Click="CloseButton_Click" FontSize="14" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource DangerBg}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- TabControl -->
            <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="10" Background="Transparent" BorderBrush="{DynamicResource BtnBorder}" BorderThickness="0,1,0,0">
                <!-- Tab 0: 界面设置 (Theme + Ribbon) -->
                <TabItem Header="界面设置">
                    <ScrollViewer Margin="10" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Theme Selector -->
                            <TextBlock Text="主题配色" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" FontSize="14" Margin="0,0,0,10"/>
                            <ItemsControl x:Name="ThemeList" Margin="0,0,0,15">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="140" Height="75" Margin="4" Cursor="Hand"
                                                Background="{DynamicResource PanelBg}" 
                                                BorderBrush="{DynamicResource WindowBorder}" BorderThickness="1"
                                                CornerRadius="5" MouseLeftButtonDown="Theme_Click">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                                            <Setter Property="BorderThickness" Value="2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <Border Width="44" Height="24" CornerRadius="3" Margin="0,0,0,6"
                                                        Background="{Binding PreviewColor}"/>
                                                <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource PrimaryText}"
                                                           FontSize="12" TextAlignment="Center"/>
                                                <TextBlock Text="{Binding Description}" Foreground="{DynamicResource SecondaryText}"
                                                           FontSize="10" TextAlignment="Center" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 1: 面板设置 -->
                <TabItem Header="面板设置">
                    <ScrollViewer Margin="10" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Ribbon 面板可见性" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" FontSize="14" Margin="0,0,0,10"/>
                            <TextBlock Text="勾选的功能在主面板显示，未勾选的折叠到下拉菜单（重启 Revit 后生效）。" 
                                       Foreground="{DynamicResource SecondaryText}" FontSize="12" Margin="0,0,0,8"/>
                            <TabControl x:Name="PanelTabControl" 
                                        Background="{DynamicResource InputBg}" 
                                        BorderBrush="{DynamicResource WindowBorder}" BorderThickness="1"
                                        MinHeight="200"/>
                            <Button x:Name="BtnSavePanel" Content="保 存 设 置" Width="140" Height="32" Margin="0,12,0,0"
                                    Background="{DynamicResource AccentColor}" Foreground="White"
                                    BorderThickness="0" FontWeight="Bold" Cursor="Hand"
                                    Click="BtnSavePanel_Click"/>
                            <TextBlock Text="提示：修改面板设置后需要重启 Revit 才会生效。" 
                                       Foreground="{DynamicResource WarningColor}" FontSize="11" Margin="0,6,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 2: 关于 -->
                <TabItem Header="关于">
                    <Grid Background="{DynamicResource PanelBg}" Margin="0,10,0,0">
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="YangTools Revit 个人插件" Foreground="{DynamicResource PrimaryText}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock x:Name="TxtGreeting" Text="Yang Revit Development Framework" Foreground="{DynamicResource SecondaryText}" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <TextBlock Text="版本：1.0.3" Foreground="{DynamicResource PrimaryText}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
                            <TextBlock Text="github.com/5788324/yang_workbuddy_revit-agent" Foreground="{DynamicResource AccentColor}" FontSize="11" HorizontalAlignment="Center" Margin="0,5,0,15"/>
                            <TextBlock Text="免责声明：本插件仅供学习与交流使用。开发者不对因使用本插件引起的任何直接或间接损失承担责任。" Foreground="{DynamicResource SecondaryText}" FontSize="12" TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- Tab 2: Hello -->
                <TabItem Header="Hello">
                    <Grid Background="{DynamicResource PanelBg}" Margin="0,10,0,0">
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="YangTools Revit 插件" Foreground="{DynamicResource PrimaryText}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="您好！Revit 插件已成功动态加载，多版本兼容环境正常运行！" Foreground="{DynamicResource SecondaryText}" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <TextBlock Text="当前操作系统类型：Windows" Foreground="{DynamicResource SecondaryText}" FontSize="13" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- Tab 3: MCP 状态 -->
                <TabItem Header="MCP 状态">
                    <Grid Margin="10,10,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Status Header -->
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
                            <Ellipse Width="12" Height="12" Fill="LimeGreen" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="MCP 服务正在运行 (Running)" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"/>
                        </StackPanel>

                        <!-- URL Info -->
                        <StackPanel Grid.Row="1" Margin="0,0,0,10">
                            <TextBlock Text="连接地址 (Server URL):" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryText}"/>
                            <TextBox Text="http://localhost:8081/mcp/" IsReadOnly="True" Background="{DynamicResource InputBg}" Foreground="{DynamicResource PrimaryText}" Padding="5" Margin="0,5,0,0" BorderBrush="{DynamicResource BtnBorder}" />
                        </StackPanel>

                        <!-- Auth Info -->
                        <StackPanel Grid.Row="2" Margin="0,0,0,15">
                            <TextBlock Text="认证密钥 (Secret Key):" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryText}"/>
                            <TextBlock Text="无 (免认证，任意本地客户端均可连接)" Foreground="{DynamicResource SecondaryText}" Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- Client Guide -->
                        <StackPanel Grid.Row="3" Margin="0,0,0,0">
                            <TextBlock Text="接入示例 (POST Request Payload):" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,5"/>
                            <TextBox TextWrapping="Wrap" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Background="{DynamicResource InputBg}" Foreground="{DynamicResource InputText}" FontFamily="Consolas" Padding="10" BorderThickness="0" AcceptsReturn="True">
                                <TextBox.Text>{
  "command": "eval_python",
  "args": {
    "script": "import clr\r\nfrom Autodesk.Revit.DB import *\r\n__result__ = 'Hello from Revit!'"
  }
}</TextBox.Text>
                            </TextBox>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
