<Window x:Class="YangTools.Revit.UI.FamilyInstanceManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="族实例管理 (Instance Manager)" Height="650" Width="1000"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True" WindowStyle="None"
        Background="Transparent">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="SharedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

        <Style TargetType="{x:Type DataGrid}" BasedOn="{StaticResource SharedDataGridStyle}">
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource SharedDataGridColumnHeaderStyle}">
        </Style>

        <!-- Group by Type -->
        <Style x:Key="TypeGroupStyle" TargetType="{x:Type GroupItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GroupItem}">
                        <StackPanel>
                            <Border Background="{DynamicResource BtnBg}" BorderBrush="{DynamicResource BtnBorder}" BorderThickness="0,1,0,1" Padding="10,5">
                                <TextBlock FontWeight="Bold" Foreground="{DynamicResource PrimaryText}">
                                    <Run Text="类型: " />
                                    <Run Text="{Binding Name, Mode=OneWay}" />
                                    <Run Text=" (" />
                                    <Run Text="{Binding ItemCount, Mode=OneWay}" />
                                    <Run Text=" 个实例)" />
                                </TextBlock>
                            </Border>
                            <ItemsPresenter />
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource WindowBg}" BorderBrush="{StaticResource WindowBorder}" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border CornerRadius="7,7,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#5C8B4C" Offset="0"/>
                        <GradientStop Color="#7AC4A6" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                        <TextBlock Text="族实例管理" Foreground="#FFFFFF" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text=" Instance Manager" Foreground="#D8E8C4" FontSize="14" Margin="5,2,0,0"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Width="30" Height="30" Background="Transparent" BorderThickness="0" Click="CloseButton_Click" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border x:Name="bg" Background="Transparent" CornerRadius="15">
                                    <Path Data="M 10,10 L 20,20 M 20,10 L 10,20" Stroke="#FFFFFF" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="{DynamicResource DangerBg}"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Main Content Tabs -->
            <TabControl x:Name="MainTabControl" Grid.Row="1" Grid.RowSpan="2" Background="Transparent" BorderThickness="0" Margin="0,10,0,0" SelectionChanged="MainTabControl_SelectionChanged">
                <TabControl.Resources>
                    <Style TargetType="{x:Type TabItem}">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type TabItem}">
                                    <Border Name="Border" Padding="15,8" Margin="2,0" BorderBrush="{StaticResource WindowBorder}" BorderThickness="1,1,1,0" CornerRadius="4,4,0,0" Background="{StaticResource PanelBg}">
                                        <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="0,2"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="{StaticResource WindowBg}"/>
                                            <Setter TargetName="Border" Property="BorderThickness" Value="1,1,1,0"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="False">
                                            <Setter TargetName="Border" Property="Background" Value="{StaticResource BtnBg}"/>
                                            <Setter Property="Foreground" Value="{StaticResource SecondaryText}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>
                
                <!-- Loadable Families Tab -->
                <TabItem Header="常规载入族 (Loadable Families)">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Filter Bar -->
                        <Border Grid.Row="0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource WindowBorder}" BorderThickness="0,0,0,1" Padding="10,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="250"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="族选择: " VerticalAlignment="Center" Foreground="{StaticResource SecondaryText}" Margin="0,0,5,0"/>
                                <ComboBox Grid.Column="1" x:Name="FamilyFilterComboBox" Margin="5,0" Padding="5" VerticalAlignment="Center" SelectionChanged="FamilyFilterChanged"/>
                                
                                <TextBlock Grid.Column="2" Text="搜索: " VerticalAlignment="Center" Foreground="{StaticResource SecondaryText}" Margin="15,0,5,0"/>
                                <TextBox Grid.Column="3" x:Name="SearchBox" Margin="5,0" Padding="5" TextChanged="SearchChanged" VerticalAlignment="Center"/>
                                
                                <Button Grid.Column="4" Content="选择图元 (Select Elements)" Click="SelectElements_Click" Margin="15,0,0,0" Padding="10,5" Background="#5C8B4C" Foreground="White" BorderThickness="0" ToolTip="隐藏窗口，在视图中选取图元进行管理"/>
                            </Grid>
                        </Border>

                        <!-- Main DataGrid -->
                        <DataGrid x:Name="InstanceDataGrid" Grid.Row="1" Margin="10" CellEditEnding="InstanceDataGrid_CellEditEnding" Visibility="Collapsed">
                            <DataGrid.GroupStyle>
                                <GroupStyle ContainerStyle="{StaticResource TypeGroupStyle}" />
                            </DataGrid.GroupStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="元素ID (ElementId)" Binding="{Binding InstanceId}" Width="Auto" IsReadOnly="True"/>
                                <DataGridTextColumn Header="类型名称 (Type)" Binding="{Binding TypeName}" Width="Auto" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Empty State Overlay -->
                        <StackPanel x:Name="EmptyStatePanel" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="请从上方选择一个族" FontSize="18" Foreground="{StaticResource SecondaryText}" HorizontalAlignment="Center"/>
                            <TextBlock Text="选择族后将显示该族的所有实例" FontSize="13" Foreground="{StaticResource SecondaryText}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- System Families Tab -->
                <TabItem Header="系统族 (System Families)">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- System Filter Bar -->
                        <Border Grid.Row="0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource WindowBorder}" BorderThickness="0,0,0,1" Padding="10,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="250"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="系统类别: " VerticalAlignment="Center" Foreground="{StaticResource SecondaryText}" Margin="0,0,5,0"/>
                                <ComboBox Grid.Column="1" x:Name="SystemCategoryComboBox" Margin="5,0" Padding="5" VerticalAlignment="Center" SelectionChanged="SystemCategoryChanged"/>
                                
                                <TextBlock Grid.Column="2" Text="搜索: " VerticalAlignment="Center" Foreground="{StaticResource SecondaryText}" Margin="15,0,5,0"/>
                                <TextBox Grid.Column="3" x:Name="SystemSearchBox" Margin="5,0" Padding="5" TextChanged="SystemSearchChanged" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- System DataGrid -->
                        <DataGrid x:Name="SystemDataGrid" Grid.Row="1" Margin="10" CellEditEnding="SystemDataGrid_CellEditEnding" Visibility="Collapsed">
                            <DataGrid.GroupStyle>
                                <GroupStyle ContainerStyle="{StaticResource TypeGroupStyle}" />
                            </DataGrid.GroupStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="元素ID (ElementId)" Binding="{Binding InstanceId}" Width="Auto" IsReadOnly="True"/>
                                <DataGridTextColumn Header="系统类型 (System Type)" Binding="{Binding TypeName}" Width="Auto" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Empty State Overlay -->
                        <StackPanel x:Name="SystemEmptyStatePanel" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="🧱" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="请从上方选择一个系统类别" FontSize="18" Foreground="{StaticResource SecondaryText}" HorizontalAlignment="Center"/>
                            <TextBlock Text="支持墙、楼板、管道、风管等系统图元" FontSize="13" Foreground="{StaticResource SecondaryText}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- Bottom Toolbar -->
            <Border Grid.Row="3" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource WindowBorder}" BorderThickness="0,1,0,0" Padding="10,5">
                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button ToolTip="在视图中选择 (Select in View)" Style="{StaticResource IconButton}" Click="SelectInView_Click" Foreground="#2196F3">
                        <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                    </Button>
                    <Button ToolTip="重置参数列 (Reset Columns)" Style="{StaticResource IconButton}" Click="ResetColumns_Click">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                    </Button>
                    <Button ToolTip="导出 Excel" Style="{StaticResource IconButton}" Click="ExportExcel_Click">
                        <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                    </Button>
                    <Button ToolTip="导入 Excel" Style="{StaticResource IconButton}" Click="ImportExcel_Click" Foreground="{DynamicResource AccentColor}">
                        <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                    </Button>
                    <Button ToolTip="删除实例 (Delete Instances)" Style="{StaticResource IconButton}" Click="Delete_Click" Foreground="#D32F2F">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                    </Button>
                </WrapPanel>
            </Border>
        </Grid>
    </Border>
</Window>
