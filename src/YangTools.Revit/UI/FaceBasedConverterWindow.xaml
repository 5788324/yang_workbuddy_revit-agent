<Window x:Class="YangTools.Revit.UI.FaceBasedConverterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="基于面族 → 常规模型族 转换工具" Width="750" Height="520"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource WindowBg}" FontFamily="Microsoft YaHei"
        WindowStyle="None" AllowsTransparency="True"
        BorderBrush="{DynamicResource WindowBorder}" BorderThickness="1">

    <Window.Resources>
        <SolidColorBrush x:Key="BtnHoverLocal" Color="{DynamicResource Color_BtnHover}"/>

        <Style x:Key="ActionButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource TitleText}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource BtnBg}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BtnHoverLocal}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="{DynamicResource TitleBarGradient}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Padding="12,8">
            <Grid>
                <TextBlock Text="基于面族 → 常规模型族 转换工具" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TitleText}" VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right" Click="CloseButton_Click" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TitleText}" Padding="5,2" Cursor="Hand" FontSize="14" Content="?"/>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource WindowBorder}" BorderThickness="0,0,0,1" Padding="10,6">
            <WrapPanel Orientation="Horizontal">
                <Button Content="?? 刷新列表" Style="{StaticResource SecondaryButton}" Click="RefreshList_Click" Margin="0,0,8,0"/>
                <Button Content="??? 从视图选择" Style="{StaticResource SecondaryButton}" Click="SelectFromView_Click" Margin="0,0,8,0"/>
                <Separator Margin="8,4"/>
                <CheckBox x:Name="ChkSelectAll" Content="全选" VerticalAlignment="Center" Margin="10,0" Click="SelectAll_Click"/>
                <TextBlock x:Name="TxtCount" Text="共 0 个基于面族类型" VerticalAlignment="Center" Foreground="{StaticResource SecondaryText}" Margin="10,0,0,0"/>
            </WrapPanel>
        </Border>

        <!-- Main DataGrid -->
        <DataGrid x:Name="FamilyDataGrid" Grid.Row="2" Margin="10" AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False" CanUserReorderColumns="False"
                  SelectionMode="Extended" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" IsReadOnly="True"
                  Background="White" BorderBrush="{StaticResource WindowBorder}" BorderThickness="1"
                  RowBackground="{DynamicResource GridRowBg}" AlternatingRowBackground="{DynamicResource GridAltRowBg}">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="选择" Width="50">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="族名称" Binding="{Binding FamilyName}" Width="*"/>
                <DataGridTextColumn Header="类型名称" Binding="{Binding TypeName}" Width="*"/>
                <DataGridTextColumn Header="实例数" Binding="{Binding InstanceCount}" Width="60"/>
                <DataGridTextColumn Header="宿主类别" Binding="{Binding HostCategory}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Options Panel -->
        <Border Grid.Row="3" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource WindowBorder}" BorderThickness="0,1,0,0" Padding="12,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="族模板: " VerticalAlignment="Center" Foreground="{StaticResource SecondaryText}" Margin="0,0,5,5"/>
                <TextBox x:Name="TxtTemplatePath" Grid.Column="1" Padding="4" Margin="0,0,5,5" IsReadOnly="True" Background="White"/>
                <Button Grid.Column="2" Content="浏览..." Style="{StaticResource SecondaryButton}" Click="BrowseTemplate_Click" Margin="0,0,0,5"/>

                <CheckBox x:Name="ChkDeleteOld" Grid.Row="1" Grid.ColumnSpan="3" Content="转换完成后删除原始基于面的实例" Margin="0,5,0,0" Foreground="{StaticResource WarningColor}" FontWeight="SemiBold"/>
                <CheckBox x:Name="cbBakeRotation" Grid.Row="2" Grid.ColumnSpan="3" Content="烘焙三维姿态 (允许倾斜/贴墙，但同类族可能会被拆分为多个类型)" Margin="0,5,0,0" Checked="cbBakeRotation_CheckedChanged" Unchecked="cbBakeRotation_CheckedChanged" />
            </Grid>
        </Border>

        <!-- Bottom Action Bar -->
        <Border Grid.Row="4" Background="{StaticResource PanelBg}" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus" Text="就绪" VerticalAlignment="Center" Foreground="{StaticResource SecondaryText}"/>
                <Button Grid.Column="1" Content="开始转换" Style="{StaticResource ActionButton}" Click="StartConvert_Click" Margin="0,0,10,0" MinWidth="100"/>
                <Button Grid.Column="2" Content="取消" Style="{StaticResource SecondaryButton}" Click="CloseButton_Click" MinWidth="80"/>
            </Grid>
        </Border>
    </Grid>
</Window>
