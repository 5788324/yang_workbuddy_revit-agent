<Window x:Class="YangTools.Revit.UI.DistributeTextWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="文本分布与对齐" Height="360" Width="320"
        AllowsTransparency="True" WindowStyle="None" WindowStartupLocation="CenterOwner"
        Background="Transparent">

    <Window.Resources>
        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="itemBd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="itemBd" Property="Background" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBd" Property="Background" Value="#7A5535"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource WindowBg}" BorderBrush="{DynamicResource WindowBorder}" BorderThickness="1" CornerRadius="4" MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border CornerRadius="3,3,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="{DynamicResource Color_TitleBarStart}" Offset="0"/>
                        <GradientStop Color="{DynamicResource Color_TitleBarEnd}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <TextBlock Text="文本分布与对齐" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="15,0,0,0" FontWeight="Bold"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Width="30" Height="30" 
                            Background="Transparent" BorderThickness="0" Foreground="#FFFFFF" FontSize="16"
                            Click="BtnCancel_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border Background="{TemplateBinding Background}" CornerRadius="0,3,0,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource DangerBg}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="20" Background="{DynamicResource PanelBg}">
                <TextBlock Text="排序方式：" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbSortBy" Background="{DynamicResource GridHover}" BorderBrush="{DynamicResource BtnBorder}" SelectedIndex="0" Margin="0,0,0,15">
                    <ComboBoxItem Content="选择顺序" Tag="SelectionOrder"/>
                    <ComboBoxItem Content="X 坐标递增 (从左到右)" Tag="XAsc"/>
                    <ComboBoxItem Content="X 坐标递减 (从右到左)" Tag="XDesc"/>
                    <ComboBoxItem Content="Y 坐标递减 (从上到下)" Tag="YDesc"/>
                    <ComboBoxItem Content="Y 坐标递增 (从下到上)" Tag="YAsc"/>
                </ComboBox>

                <TextBlock Text="分布方向：" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbDistributeDir" Background="{DynamicResource GridHover}" BorderBrush="{DynamicResource BtnBorder}" SelectedIndex="1" Margin="0,0,0,15">
                    <ComboBoxItem Content="不分布 (仅对齐)" Tag="None"/>
                    <ComboBoxItem Content="沿 Y 轴 (垂直间距)" Tag="Y"/>
                    <ComboBoxItem Content="沿 X 轴 (水平间距)" Tag="X"/>
                </ComboBox>

                <TextBlock Text="固定间距 (mm)：" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,5"/>
                <TextBox x:Name="txtSpacing" Text="500" Background="{DynamicResource GridHover}" BorderBrush="{DynamicResource BtnBorder}" Padding="4" Margin="0,0,0,15"/>

                <TextBlock Text="基线对齐方式：" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbAlignMode" Background="{DynamicResource GridHover}" BorderBrush="{DynamicResource BtnBorder}" SelectedIndex="1">
                    <ComboBoxItem Content="保持原状" Tag="None"/>
                    <ComboBoxItem Content="对齐到第一个元素的 X (垂直排版用)" Tag="AlignX"/>
                    <ComboBoxItem Content="对齐到第一个元素的 Y (水平排版用)" Tag="AlignY"/>
                </ComboBox>
            </StackPanel>

            <!-- Bottom Bar -->
            <Border Grid.Row="2" Background="{DynamicResource BottomBarBg}" BorderBrush="{DynamicResource BtnBorder}" BorderThickness="0,1,0,0" CornerRadius="0,0,3,3">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,15,0">
                    <Button Content="取消" Width="70" Height="28" Margin="0,0,10,0" Click="BtnCancel_Click"
                            Background="{DynamicResource BtnBg}" BorderBrush="{DynamicResource BtnBorder}" Foreground="{DynamicResource PrimaryText}"/>
                    <Button Content="确定" Width="70" Height="28" Click="BtnOk_Click"
                            Background="{DynamicResource AccentColor}" BorderBrush="{DynamicResource AccentHover}" Foreground="#FFFFFF" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
