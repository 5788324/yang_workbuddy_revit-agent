<Window x:Class="YangTools.Revit.UI.BooleanGeometryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="布尔几何" Height="380" Width="520"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" MouseDown="Window_MouseDown">
    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="WindowBgBrush" Color="{DynamicResource WindowBg}" />
        <SolidColorBrush x:Key="WindowBorderBrush" Color="{DynamicResource WindowBorder}" />
        <SolidColorBrush x:Key="CardBgBrush" Color="{DynamicResource PanelBg}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource PrimaryText}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource SecondaryText}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
        <SolidColorBrush x:Key="ButtonBgBrush" Color="{DynamicResource BtnBg}" />
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="{DynamicResource BtnBorder}" />
        <SolidColorBrush x:Key="BottomBarBgBrush" Color="{DynamicResource BottomBarBg}" />

        <Style x:Key="StandardButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource ButtonBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource BtnHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource StandardButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" Padding="15,5">
                            <TextBlock Text="✕" FontSize="14" Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource DangerBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style TargetType="{x:Type RadioButton}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
        </Style>
        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource WindowBgBrush}" BorderBrush="{StaticResource WindowBorderBrush}" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" CornerRadius="8,8,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="{DynamicResource Color_TitleBarStart}" Offset="0"/>
                        <GradientStop Color="{DynamicResource Color_TitleBarEnd}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <TextBlock Text="布尔几何" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" Margin="15,10" VerticalAlignment="Center"/>
                    <Button Style="{StaticResource CloseButtonStyle}" HorizontalAlignment="Right" Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Source & Target -->
                <Border Grid.Row="0" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource WindowBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="选择主体实例" Style="{StaticResource StandardButtonStyle}" Click="BtnSelectMain_Click" Width="120" HorizontalAlignment="Left"/>
                            <TextBlock x:Name="TxtMain" Grid.Column="1" Text="未选择" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                        
                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="选择融合实例" Style="{StaticResource StandardButtonStyle}" Click="BtnSelectUnion_Click" Width="120" HorizontalAlignment="Left"/>
                            <TextBlock x:Name="TxtUnion" Grid.Column="1" Text="未选择" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                        
                        <Grid Grid.Row="2" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="选择剪切实例" Style="{StaticResource StandardButtonStyle}" Click="BtnSelectCut_Click" Width="120" HorizontalAlignment="Left"/>
                            <TextBlock x:Name="TxtCut" Grid.Column="1" Text="未选择" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>

                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="选择连接实例" Style="{StaticResource StandardButtonStyle}" Click="BtnSelectJoin_Click" Width="120" HorizontalAlignment="Left"/>
                            <TextBlock x:Name="TxtJoin" Grid.Column="1" Text="未选择" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Options -->
                <TextBlock Grid.Row="3" Text="选项" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                <StackPanel Grid.Row="4">
                    <CheckBox x:Name="ChkDeleteTargetInst" Content="删除目标图元 (Delete Target Instance)"/>
                    <CheckBox x:Name="ChkDeleteTargetFam" Content="从项目中彻底删除目标族 (Delete Target Family)"/>
                </StackPanel>
            </Grid>

            <!-- Bottom Bar -->
            <Border Grid.Row="2" Background="{StaticResource BottomBarBgBrush}" BorderBrush="{StaticResource WindowBorderBrush}" BorderThickness="0,1,0,0" CornerRadius="0,0,8,8" Padding="15,10">
                <Grid>
                    <TextBlock x:Name="TxtStatus" Text="" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="取消" Style="{StaticResource StandardButtonStyle}" Margin="0,0,10,0" Click="CloseButton_Click"/>
                        <Button Content="执行 (Execute)" Style="{StaticResource PrimaryButtonStyle}" Click="BtnExecute_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
