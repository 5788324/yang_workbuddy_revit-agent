<Window x:Class="YangTools.Revit.UI.AlignTextToLineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="对齐到线" Height="250" Width="300"
        AllowsTransparency="True" WindowStyle="None" WindowStartupLocation="CenterOwner"
        Background="Transparent">

    <Window.Resources>
        <!-- ComboBoxItem Style -->
        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="itemBd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="itemBd" Property="Background" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TitleText}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBd" Property="Background" Value="{DynamicResource GridSelected}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TitleText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource WindowBg}" BorderBrush="{DynamicResource WindowBorder}" BorderThickness="1" CornerRadius="4" MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border CornerRadius="3,3,0,0" Background="{DynamicResource TitleBarGradient}">
                <Grid>
                    <TextBlock Text="对齐到线" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="15,0,0,0" FontWeight="Bold"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Width="30" Height="30" 
                            Background="Transparent" BorderThickness="0" Foreground="#FFFFFF" FontSize="16"
                            Click="BtnCancel_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border Background="{TemplateBinding Background}" CornerRadius="0,3,0,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource DangerBg}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="20" Background="{DynamicResource PanelBg}">
                <CheckBox x:Name="chkKeepUpright" Content="保持文字正向" Foreground="{DynamicResource PrimaryText}" IsChecked="True" Margin="0,0,0,15"/>
                
                <TextBlock Text="基点对齐方式：" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbAlignBase" Background="{DynamicResource GridHover}" BorderBrush="{DynamicResource BtnBorder}" SelectedIndex="0">
                    <ComboBoxItem Content="保持原点" Tag="Retain"/>
                    <ComboBoxItem Content="对齐到起点" Tag="Start"/>
                    <ComboBoxItem Content="对齐到终点" Tag="End"/>
                </ComboBox>
            </StackPanel>

            <!-- Bottom Bar -->
            <Border Grid.Row="2" Background="{DynamicResource BottomBarBg}" BorderBrush="{DynamicResource BtnBorder}" BorderThickness="0,1,0,0" CornerRadius="0,0,3,3">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,15,0">
                    <Button Content="取消" Width="70" Height="28" Margin="0,0,10,0" Click="BtnCancel_Click"
                            Background="{DynamicResource BtnBg}" BorderBrush="{DynamicResource BtnBorder}" Foreground="{DynamicResource PrimaryText}"/>
                    <Button Content="确定" Width="70" Height="28" Click="BtnOk_Click"
                            Background="{DynamicResource AccentColor}" BorderBrush="{DynamicResource AccentHover}" Foreground="{DynamicResource TitleText}" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
