<Window x:Class="YangTools.Revit.UI.BatchTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="总控批处理与云链接" Height="750" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBg}" Foreground="{DynamicResource PrimaryText}">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="SharedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <Style TargetType="{x:Type Button}">
                <Setter Property="Background" Value="{DynamicResource BtnBg}"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BtnBorder}"/>
                <Setter Property="Padding" Value="10,5"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>
            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style TargetType="{x:Type CheckBox}">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,10,0"/>
            </Style>
            <Style TargetType="{x:Type ComboBox}">
                <Setter Property="Margin" Value="3"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="MinWidth" Value="120"/>
            </Style>
            <Style TargetType="{x:Type TextBox}">
                <Setter Property="Margin" Value="3"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="MinWidth" Value="120"/>
                <Setter Property="Padding" Value="2"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="批处理任务配置" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>

        <!-- 目标文档列表 -->
        <Border Grid.Row="1" BorderBrush="{DynamicResource WindowBorder}" BorderThickness="1" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="目标文档 (逐个处理导出)" FontWeight="Bold" Margin="0,0,10,0"/>
                    <Button Content="+ 添加模型(RVT)" Click="BtnAddDocument_Click"/>
                </StackPanel>
                <ItemsControl Grid.Row="1" ItemsSource="{Binding Documents}" Margin="0,5,0,0">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Enabled}" Content="{Binding DisplayName}" Margin="0,0,15,2"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
        
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 链接管理 -->
            <Border BorderBrush="{DynamicResource WindowBorder}" BorderThickness="1" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="1. 链接管理 (Revit/CAD)" FontWeight="Bold"/>
                        <Button Content="+ 添加" Click="BtnAddFile_Click" Margin="15,0,0,0"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Links}" AutoGenerateColumns="False" CanUserAddRows="False" 
                              Style="{StaticResource SharedDataGridStyle}" MinHeight="100">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="文件名" Binding="{Binding FileName}" Width="*"/>
                            <DataGridTemplateColumn Header="移除" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" Click="BtnRemoveLink_Click" Margin="2" Padding="5,2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
            
            <!-- 导出管理 -->
            <Border Grid.Column="2" BorderBrush="{DynamicResource WindowBorder}" BorderThickness="1" Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="2. 导出管理" FontWeight="Bold" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="输出路径:"/>
                            <TextBox Text="{Binding OutputFolder}" Width="250"/>
                            <Button Content="浏览" Click="BtnBrowseOutput_Click"/>
                        </StackPanel>
                        
                        <!-- NWC: 三维视图 -->
                        <Border BorderBrush="{DynamicResource WindowBorder}" BorderThickness="0,0,0,1" Padding="3">
                            <StackPanel>
                                <CheckBox IsChecked="{Binding EnableNwc}" Content="导出 NWC (Navisworks)"/>
                                <StackPanel Visibility="{Binding EnableNwc, Converter={StaticResource BoolToVis}}" Margin="15,3,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="三维视图:" Width="65"/>
                                        <ComboBox ItemsSource="{Binding Available3DViews}" SelectedItem="{Binding SelectedNwc3DView}" Width="160"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="文件名:" Width="65"/>
                                        <TextBox Text="{Binding NwcFileName}" Width="160"/>
                                        <TextBlock Text=".nwc" Foreground="{DynamicResource SecondaryText}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- IFC: 三维视图 -->
                        <Border BorderBrush="{DynamicResource WindowBorder}" BorderThickness="0,0,0,1" Padding="3">
                            <StackPanel>
                                <CheckBox IsChecked="{Binding EnableIfc}" Content="导出 IFC"/>
                                <StackPanel Visibility="{Binding EnableIfc, Converter={StaticResource BoolToVis}}" Margin="15,3,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="IFC版本:" Width="65"/>
                                        <ComboBox ItemsSource="{Binding AvailableIfcVersions}" SelectedItem="{Binding SelectedIfcVersion}" Width="90"/>
                                        <TextBlock Text="三维视图:" Margin="10,0,0,0" Width="55"/>
                                        <ComboBox ItemsSource="{Binding Available3DViews}" SelectedItem="{Binding SelectedIfc3DView}" Width="130"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="文件名:" Width="65"/>
                                        <TextBox Text="{Binding IfcFileName}" Width="160"/>
                                        <TextBlock Text=".ifc" Foreground="{DynamicResource SecondaryText}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <!-- DWG: 图纸/视图集 -->
                        <Border BorderBrush="{DynamicResource WindowBorder}" BorderThickness="0,0,0,1" Padding="3">
                            <StackPanel>
                                <CheckBox IsChecked="{Binding EnableDwg}" Content="导出 CAD (DWG)"/>
                                <StackPanel Visibility="{Binding EnableDwg, Converter={StaticResource BoolToVis}}" Margin="15,3,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="导出设置:" Width="65"/>
                                        <ComboBox ItemsSource="{Binding AvailableDwgSetups}" SelectedItem="{Binding SelectedDwgSetup}" Width="130"/>
                                        <TextBlock Text="图纸/视图集:" Margin="8,0,0,0" Width="70"/>
                                        <ComboBox ItemsSource="{Binding AvailableViewSheetSets}" SelectedItem="{Binding SelectedDwgViewSheetSet}" Width="130"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="文件名:" Width="65"/>
                                        <TextBox Text="{Binding DwgFileName}" Width="120"/>
                                        <TextBlock Text="(按导出设置命名时忽略)" Foreground="{DynamicResource SecondaryText}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <!-- PDF -->
                        <Border BorderBrush="{DynamicResource WindowBorder}" BorderThickness="0,0,0,1" Padding="3">
                            <StackPanel>
                                <CheckBox IsChecked="{Binding EnablePdf}" Content="导出 PDF"/>
                                <StackPanel Visibility="{Binding EnablePdf, Converter={StaticResource BoolToVis}}" Margin="15,3,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="PDF设置:" Width="65"/>
                                        <ComboBox ItemsSource="{Binding AvailablePdfSetups}" SelectedItem="{Binding SelectedPdfSetup}" Width="130"/>
                                        <TextBlock Text="图纸/视图集:" Margin="8,0,0,0" Width="70"/>
                                        <ComboBox ItemsSource="{Binding AvailableViewSheetSets}" SelectedItem="{Binding SelectedPdfViewSheetSet}" Width="130"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding PdfCombine}" Content="合并为单个PDF"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="文件名:" Width="65"/>
                                        <TextBox Text="{Binding PdfFileName}" Width="160"/>
                                        <TextBlock Text=".pdf" Foreground="{DynamicResource SecondaryText}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
        
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TxtProgress" Foreground="{DynamicResource SecondaryText}" 
                       Text="准备就绪。支持本地RVT模型和Desktop Connector云模型。"/>
            <Button Grid.Column="1" Content="▶ 执行批处理" Width="140" Height="40" 
                    Click="BtnExecute_Click" FontWeight="Bold"
                    Background="{DynamicResource AccentColor}" Foreground="White" BorderThickness="0"/>
        </Grid>
    </Grid>
</Window>
