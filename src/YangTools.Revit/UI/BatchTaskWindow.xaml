<Window x:Class="YangTools.Revit.UI.BatchTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="总控批处理与云链接 (GUI 版)" Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource PrimaryText}">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="SharedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <Style TargetType="{x:Type Button}">
                <Setter Property="Background" Value="{StaticResource BtnBg}"/>
                <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BtnBorder}"/>
                <Setter Property="Padding" Value="10,5"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BtnHover}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style TargetType="{x:Type CheckBox}">
                <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,10,0"/>
            </Style>
            <Style TargetType="{x:Type ComboBox}">
                <Setter Property="Margin" Value="5"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Width" Value="150"/>
            </Style>
            <Style TargetType="{x:Type TextBox}">
                <Setter Property="Margin" Value="5"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Width" Value="150"/>
                <Setter Property="Padding" Value="2"/>
            </Style>
            
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="批处理任务配置" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Link Settings -->
            <Border BorderBrush="{StaticResource WindowBorder}" BorderThickness="1" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="1. 链接管理 (Revit/CAD)" FontWeight="Bold"/>
                        <Button Content="+ 添加文件" Click="BtnAddFile_Click" Margin="20,0,0,0"/>
                    </StackPanel>
                    
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Links}" AutoGenerateColumns="False" CanUserAddRows="False" Style="{StaticResource SharedDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="文件名" Binding="{Binding FileName}" Width="*"/>
                            <DataGridTemplateColumn Header="操作" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="移除" Click="BtnRemoveLink_Click" Margin="2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
            
            <!-- Export Settings -->
            <Border Grid.Column="2" BorderBrush="{StaticResource WindowBorder}" BorderThickness="1" Padding="10">
                <StackPanel>
                    <TextBlock Text="2. 导出管理" FontWeight="Bold" Margin="0,0,0,10"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="统一输出路径: "/>
                        <TextBox Text="{Binding OutputFolder}" Width="300"/>
                        <Button Content="浏览" Click="BtnBrowseOutput_Click"/>
                    </StackPanel>
                    
                    <!-- NWC Export -->
                    <Border BorderBrush="{StaticResource WindowBorder}" BorderThickness="0,0,0,1" Padding="5">
                        <StackPanel>
                            <CheckBox IsChecked="{Binding EnableNwc}" Content="导出 NWC (Navisworks)"/>
                            <StackPanel Visibility="{Binding EnableNwc, Converter={StaticResource BoolToVis}}" Margin="20,5,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="图纸/视图集: " VerticalAlignment="Center" Width="80"/>
                                    <ComboBox ItemsSource="{Binding AvailableViewSheetSets}" SelectedItem="{Binding NwcViewSetName}" Width="200"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="导出文件名前缀: " VerticalAlignment="Center" Width="100"/>
                                    <TextBox Text="{Binding NwcFileName}" Width="200"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- IFC Export -->
                    <Border BorderBrush="{StaticResource WindowBorder}" BorderThickness="0,0,0,1" Padding="5">
                        <StackPanel>
                            <CheckBox IsChecked="{Binding EnableIfc}" Content="导出 IFC"/>
                            <StackPanel Visibility="{Binding EnableIfc, Converter={StaticResource BoolToVis}}" Margin="20,5,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="IFC版本: " VerticalAlignment="Center" Width="80"/>
                                    <ComboBox ItemsSource="{Binding AvailableIfcVersions}" SelectedItem="{Binding SelectedIfcVersion}" Width="100" Margin="0,0,20,0"/>
                                    <TextBlock Text="图纸/视图集: " VerticalAlignment="Center"/>
                                    <ComboBox ItemsSource="{Binding AvailableViewSheetSets}" SelectedItem="{Binding IfcViewSetName}" Width="150"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="导出文件名前缀: " VerticalAlignment="Center" Width="100"/>
                                    <TextBox Text="{Binding IfcFileName}" Width="200"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- DWG Export -->
                    <Border BorderBrush="{StaticResource WindowBorder}" BorderThickness="0,0,0,1" Padding="5">
                        <StackPanel>
                            <CheckBox IsChecked="{Binding EnableDwg}" Content="导出 CAD (DWG)"/>
                            <StackPanel Visibility="{Binding EnableDwg, Converter={StaticResource BoolToVis}}" Margin="20,5,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="导出设置: "/>
                                    <ComboBox ItemsSource="{Binding AvailableDwgSetups}" SelectedItem="{Binding SelectedDwgSetup}"/>
                                    <TextBlock Text="图纸/视图集: " Margin="10,0,0,0"/>
                                    <ComboBox ItemsSource="{Binding AvailableDwgViewSheetSets}" SelectedItem="{Binding SelectedDwgViewSheetSet}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="导出文件名前缀: "/>
                                    <TextBox Text="{Binding DwgFileName}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- PDF Export -->
                    <Border BorderBrush="{StaticResource WindowBorder}" BorderThickness="0,0,0,1" Padding="5">
                        <StackPanel>
                            <CheckBox IsChecked="{Binding EnablePdf}" Content="导出 PDF 图纸集"/>
                            <StackPanel Visibility="{Binding EnablePdf, Converter={StaticResource BoolToVis}}" Margin="20,5,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="PDF设置: " VerticalAlignment="Center" Width="80"/>
                                    <ComboBox ItemsSource="{Binding AvailablePdfSetups}" SelectedItem="{Binding SelectedPdfSetup}" Width="150" Margin="0,0,20,0"/>
                                    <TextBlock Text="图纸/视图集: " VerticalAlignment="Center"/>
                                    <ComboBox ItemsSource="{Binding AvailableViewSheetSets}" SelectedItem="{Binding SelectedPdfViewSheetSet}" Width="150"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <CheckBox IsChecked="{Binding PdfCombine}" Content="合并为单个PDF文件" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="文件名/前缀: " VerticalAlignment="Center" Width="80"/>
                                    <TextBox Text="{Binding PdfFileName}" Width="200"/>
                                    <TextBlock Text=".pdf" VerticalAlignment="Center" Foreground="{StaticResource SecondaryText}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                </StackPanel>
            </Border>
        </Grid>
        
        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TxtProgress" Foreground="{DynamicResource SecondaryText}" Text="准备就绪。所有的链接文件（包含局域网与Desktop Connector云路径）将被静默加载。"/>
            <Button Grid.Column="1" Content="执行批处理" Width="150" Height="40" Click="BtnExecute_Click" FontWeight="Bold"/>
        </Grid>
    </Grid>
</Window>
